      {
        "Endpoint": "POST:/scim/v2/Users",
        "Period": "60s",
        "Limit": 20
      },
      {
        "Endpoint": "PUT:/scim/v2/Users/*",
        "Period": "60s",
        "Limit": 30
      },
      {
        "Endpoint": "PATCH:/scim/v2/Users/*",
        "Period": "60s",
        "Limit": 30
      },
      {
        "Endpoint": "DELETE:/scim/v2/Users/*",
        "Period": "60s",
        "Limit": 10
      },
      {
        "Endpoint": "GET:/scim/v2/Groups",
        "Period": "60s",
        "Limit": 30
