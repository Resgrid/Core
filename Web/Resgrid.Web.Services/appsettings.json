{
  "AppOptions": {
    "ConfigPath": "C:\\Resgrid\\Config\\ResgridConfig.json"
  },
  "ConnectionStrings": {
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",
