@using Resgrid.Framework
@model Resgrid.Web.Areas.User.Models.Calendar.EditCalendarCheckInView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Calendar.Calendar> localizer
@{
    ViewBag.Title = "Resgrid | " + @localizer["EditCheckInTimes"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["EditCheckInTimes"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li>
                <a asp-controller="Calendar" asp-action="Index" asp-route-area="User">@commonLocalizer["CalendarModule"]</a>
            </li>
            <li class="active">
                <strong>@localizer["EditCheckInTimes"]</strong>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <form class="form-horizontal" role="form" asp-controller="Calendar" asp-action="EditCheckIn" asp-route-area="User" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CheckIn.CalendarItemCheckInId" value="@Model.CheckIn.CalendarItemCheckInId" />

                        <div class="form-group">
                            <label class="col-sm-3 control-label">@localizer["CheckInTime"]</label>
                            <div class="col-sm-9">
                                <input type="text" id="CheckInTime" name="CheckIn.CheckInTime"
                                       value="@Model.CheckIn.CheckInTime.ToString("MM/dd/yyyy HH:mm")"
                                       class="form-control" style="width:250px;" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-3 control-label">@localizer["CheckOutTime"]</label>
                            <div class="col-sm-9">
                                <input type="text" id="CheckOutTime" name="CheckIn.CheckOutTime"
                                       value="@(Model.CheckIn.CheckOutTime?.ToString("MM/dd/yyyy HH:mm") ?? "")"
                                       class="form-control" style="width:250px;" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-3 control-label">@localizer["CheckInNote"]</label>
                            <div class="col-sm-9">
                                <input type="text" name="CheckIn.CheckInNote" value="@Model.CheckIn.CheckInNote" class="form-control" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-3 control-label">@localizer["CheckOutNote"]</label>
                            <div class="col-sm-9">
                                <input type="text" name="CheckIn.CheckOutNote" value="@Model.CheckIn.CheckOutNote" class="form-control" />
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="col-sm-4 col-sm-offset-3">
                                <a class="btn btn-white" asp-controller="Calendar" asp-action="View" asp-route-area="User" asp-route-calendarItemId="@Model.CheckIn.CalendarItemId">@commonLocalizer["Cancel"]</a>
                                <button class="btn btn-primary" type="submit">@commonLocalizer["Save"]</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
<script>
    $(document).ready(function () {
        $("#CheckInTime").datetimepicker({ step: 5 });
        $("#CheckOutTime").datetimepicker({ step: 5 });
    });
</script>
}
