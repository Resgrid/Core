@using Resgrid.Framework
@model Resgrid.Web.Areas.User.Models.Calendar.CalendarItemView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Calendar.Calendar> localizer
@{
    ViewBag.Title = "Resgrid | " + @localizer["CalendarItemHeader"];
}
@section Styles
{
    <style>
        .event-header-panel {
            border-left: 4px solid #1ab394;
            padding: 20px 24px;
            background: #fff;
        }
        .event-header-panel .event-title {
            font-size: 24px;
            font-weight: 600;
            margin: 0 0 6px;
            color: #222;
        }
        .event-header-panel .event-meta {
            color: #888;
            font-size: 13px;
        }
        .event-header-panel .event-meta i {
            width: 16px;
            text-align: center;
            margin-right: 4px;
        }
        .event-date-badge {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #1ab394;
            color: #fff;
            border-radius: 6px;
            width: 72px;
            min-height: 72px;
            text-align: center;
            padding: 8px 4px;
            flex-shrink: 0;
        }
        .event-date-badge .badge-day {
            font-size: 30px;
            font-weight: 700;
            line-height: 1;
        }
        .event-date-badge .badge-month {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            line-height: 1.2;
        }
        .event-date-badge .badge-year {
            font-size: 11px;
            opacity: 0.85;
            line-height: 1.2;
        }
        .event-header-flex {
            display: flex;
            align-items: flex-start;
            gap: 20px;
        }
        .event-header-body {
            flex: 1;
        }
        .detail-label {
            font-weight: 600;
            color: #555;
            white-space: nowrap;
        }
        @@media (max-width: 767px) {
            .event-header-flex {
                flex-direction: column;
            }
        }
    </style>
}
<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["CalendarItemHeader"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li>
                <a asp-controller="Calendar" asp-action="Index" asp-route-area="User">@commonLocalizer["CalendarModule"]</a>
            </li>
            <li class="active">
                <strong>@localizer["CalendarItemHeader"]</strong>
            </li>
        </ol>
    </div>
    <div class="col-sm-8">
        <div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
            <div class="buttons-actions">
                @if (Model.CanEdit && Model.IsRecurrenceParent == false)
                {
                    <a asp-controller="Calendar" asp-action="DeleteCalendarItem" asp-route-area="User" asp-route-itemId="@Model.CalendarItem.CalendarItemId"
                       class="btn btn-danger" onclick="return confirm('@localizer["DeleteEventConfirm"]');">
                        <i class="fa fa-trash"></i> @localizer["DeleteEvent"]
                    </a>
                }
                else if (Model.CanEdit)
                {
                    <a asp-controller="Calendar" asp-action="DeleteAllCalendarItems" asp-route-area="User" asp-route-itemId="@Model.CalendarItem.CalendarItemId"
                       class="btn btn-danger" onclick="return confirm('@localizer["DeleteEventOccurrencesConfirm"]');">
                        <i class="fa fa-trash"></i> @localizer["DeleteEventOccurrences"]
                    </a>
                }
                @if (Model.CanEdit)
                {
                    <a asp-controller="Calendar" asp-action="Edit" asp-route-area="User" asp-route-id="@Model.CalendarItem.CalendarItemId"
                       class="btn btn-success">
                        <i class="fa fa-pencil"></i> @localizer["EditEvent"]
                    </a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ExportIcsUrl))
                {
                    <a href="@Model.ExportIcsUrl" class="btn btn-info">
                        <i class="fa fa-download"></i> @localizer["DownloadIcs"]
                    </a>
                }
                @if (Model.CanEdit)
                {
                    <a href="@Url.Action("SignupSheet", "Calendar", new { area = "User", calendarItemId = Model.CalendarItem.CalendarItemId })"
                       class="btn btn-warning" target="_blank">
                        <i class="fa fa-print"></i> @localizer["PrintSignupSheet"]
                    </a>
                }
            </div>
        </div>
    </div>
</div>
<div class="wrapper wrapper-content animated fadeInUp">
    @* Event header *@
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-content event-header-panel">
                    <div class="event-header-flex">
                        <div class="event-date-badge">
                            <span class="badge-day">@Model.CalendarItem.Start.TimeConverter(Model.Department).Day</span>
                            <span class="badge-month">@DateTimeHelpers.MonthToShortString(Model.CalendarItem.Start.TimeConverter(Model.Department).Month)</span>
                            <span class="badge-year">@Model.CalendarItem.Start.TimeConverter(Model.Department).Year</span>
                        </div>
                        <div class="event-header-body">
                            <h2 class="event-title">@Model.CalendarItem.Title</h2>
                            <div class="event-meta">
                                <span class="m-r-md">
                                    <i class="fa fa-clock-o"></i>
                                    @if (Model.CalendarItem.IsAllDay)
                                    {
                                        if (Model.CalendarItem.IsMultiDay)
                                        {
                                            @string.Format(localizer["DateRange"],
                                                Model.CalendarItem.Start.TimeConverter(Model.Department).ToShortDateString(),
                                                Model.CalendarItem.End.TimeConverter(Model.Department).ToShortDateString())
                                        }
                                        else
                                        {
                                            @localizer["AllDayEvent"]
                                        }
                                    }
                                    else
                                    {
                                        @Model.CalendarItem.Start.TimeConverter(Model.Department).ToShortTimeString()
                                        <span> &ndash; </span>
                                        @Model.CalendarItem.End.TimeConverter(Model.Department).ToShortTimeString()
                                    }
                                </span>
                                @if (!string.IsNullOrWhiteSpace(Model.CalendarItem.Location))
                                {
                                    <span class="m-r-md">
                                        <i class="fa fa-map-marker"></i> @Model.CalendarItem.Location
                                    </span>
                                }
                                @if (Model.CalendarItem.IsAllDay)
                                {
                                    <span class="label label-primary">@localizer["AllDayEvent"]</span>
                                }
                                @if (Model.IsRecurrenceParent)
                                {
                                    <span class="label label-warning m-l-xs"><i class="fa fa-repeat"></i> Recurring</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* Details + Map *@
    <div class="row">
        <div class="col-lg-7">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-info-circle"></i> @commonLocalizer["Details"]</h5>
                </div>
                <div class="ibox-content">
                    <dl class="dl-horizontal">
                        <dt class="detail-label">@commonLocalizer["Start"]</dt>
                        <dd>
                            @if (Model.CalendarItem.IsAllDay)
                            {
                                @Model.CalendarItem.Start.TimeConverter(Model.Department).ToString("dd MMMM yyyy")
                            }
                            else
                            {
                                @Model.CalendarItem.Start.TimeConverter(Model.Department).ToString("dd MMMM yyyy h:mm tt")
                            }
                        </dd>
                        <dt class="detail-label">@commonLocalizer["End"]</dt>
                        <dd>
                            @if (Model.CalendarItem.IsAllDay)
                            {
                                @Model.CalendarItem.End.TimeConverter(Model.Department).ToString("dd MMMM yyyy")
                            }
                            else
                            {
                                @Model.CalendarItem.End.TimeConverter(Model.Department).ToString("dd MMMM yyyy h:mm tt")
                            }
                        </dd>
                        @if (!string.IsNullOrWhiteSpace(Model.CalendarItem.Location))
                        {
                            <dt class="detail-label">@commonLocalizer["Location"]</dt>
                            <dd>@Model.CalendarItem.Location</dd>
                        }
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(Model.CalendarItem.Description))
                    {
                        <hr />
                        <h4 class="m-t-none m-b-sm">@commonLocalizer["Description"]</h4>
                        <div class="well well-sm" style="background:#f9f9f9; border:none;">
                            @Html.Raw(Model.CalendarItem.Description)
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-map-marker"></i> @commonLocalizer["Location"]</h5>
                </div>
                <div class="ibox-content" style="padding:0; min-height:220px; overflow:hidden;">
                    <div id="map" name="map" style="width:100%; height:220px;"></div>
                </div>
            </div>
        </div>
    </div>
    @* Attendees *@
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-users"></i> Attendees</h5>
                    <div class="ibox-tools">
                        <span class="badge">@Model.CalendarItem.Attendees.Count</span>
                    </div>
                </div>
                <div class="ibox-content">
                    @if (Model.CalendarItem.Attendees.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover no-margins">
                                <thead>
                                    <tr>
                                        <th>@commonLocalizer["Name"]</th>
                                        <th>@commonLocalizer["Timestamp"]</th>
                                        <th>@commonLocalizer["Type"]</th>
                                        <th>@commonLocalizer["Note"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attendee in Model.CalendarItem.Attendees)
                                    {
                                        <tr>
                                            <td>@(await UserHelper.GetFullNameForUser(attendee.UserId))</td>
                                            <td><small class="text-muted">@attendee.Timestamp.TimeConverterToString(Model.Department)</small></td>
                                            <td>
                                                @if (attendee.AttendeeType == 1)
                                                {
                                                    <span class="label label-success">@localizer["RSVP"]</span>
                                                }
                                                else if (attendee.AttendeeType == 2)
                                                {
                                                    <span class="label label-warning">@commonLocalizer["Required"]</span>
                                                }
                                                else
                                                {
                                                    <span class="label label-default">@commonLocalizer["Optional"]</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(attendee.Note))
                                                {
                                                    <span>@attendee.Note</span>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">@localizer["NoNote"]</small>
                                                }
                                            </td>
                                            <td class="text-right">
                                                @if (attendee.UserId == ClaimsAuthorizationHelper.GetUserId() && Model.CalendarItem.Start >= DateTime.UtcNow)
                                                {
                                                    <a title="@localizer["RemoveHelp"]" class="btn btn-xs btn-danger"
                                                       href="@Url.Action("RemoveFromEvent", "Calendar", new { area = "User", id = attendee.CalendarItemAttendeeId })">
                                                        <i class="fa fa-times"></i> @localizer["RemoveMe"]
                                                    </a>
                                                }
                                                else if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
                                                {
                                                    <a title="@localizer["RemoveHelp"]" class="btn btn-xs btn-danger"
                                                       href="@Url.Action("RemoveFromEvent", "Calendar", new { area = "User", id = attendee.CalendarItemAttendeeId })">
                                                        <i class="fa fa-times"></i> @commonLocalizer["Remove"]
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted" style="padding:30px 0;">
                            <i class="fa fa-users fa-2x" style="opacity:.3; display:block; margin-bottom:8px;"></i>
                            No attendees yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    @* Signup form — admins/creators can sign up people even after the event has passed *@
    @if (Model.CalendarItem.SignupType != 0 && !Model.CalendarItem.IsUserAttending(Model.UserId) && (Model.CalendarItem.Start >= DateTime.UtcNow || Model.IsAdmin))
    {
        <div class="row">
            <div class="col-lg-6">
                <div class="ibox float-e-margins">
                    <div class="ibox-title">
                        <h5><i class="fa fa-check-square-o"></i> @localizer["Signup"]</h5>
                    </div>
                    <div class="ibox-content">
                        @using (Html.BeginForm("Signup", "Calendar", FormMethod.Post, new { area = "User", @class = "form-horizontal" }))
                        {
                            @Html.HiddenFor(m => m.CalendarItem.CalendarItemId)
                            <div class="form-group">
                                <label class="col-sm-3 control-label">@commonLocalizer["Note"]</label>
                                <div class="col-sm-9">
                                    @Html.TextAreaFor(m => m.Note, new { rows = "5", @class = "form-control" })
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-sm-offset-3 col-sm-9">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa fa-check"></i> @localizer["Signup"]
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    @* Self Check-In / Check-Out *@
    @if (Model.CalendarItem.CheckInType != (int)Resgrid.Model.CalendarItemCheckInTypes.Disabled)
    {
        @* Show self check-in panel if SelfCheckIn mode, or if AdminOnly and user is admin/creator/group-admin *@
        var showSelfPanel = Model.CalendarItem.CheckInType == (int)Resgrid.Model.CalendarItemCheckInTypes.SelfCheckIn || Model.IsAdmin;
        var checkInWindowOpen = DateTime.UtcNow >= Model.CalendarItem.Start.AddMinutes(-15);
        var eventIsPast = DateTime.UtcNow > Model.CalendarItem.End;
        @* Admins/creators can always check in/out (even after event has passed) for bookkeeping *@
        var adminBypassWindow = Model.IsAdmin;
        if (showSelfPanel)
        {
    <div class="row">
        <div class="col-lg-6">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5><i class="fa fa-clock-o"></i> @localizer["CheckIn"] / @localizer["CheckOut"]</h5>
                </div>
                <div class="ibox-content">
                    @if (Model.UserCheckIn == null && (checkInWindowOpen || adminBypassWindow))
                    {
                        @using (Html.BeginForm("CheckIn", "Calendar", FormMethod.Post, new { area = "User" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="calendarItemId" value="@Model.CalendarItem.CalendarItemId" />
                            <div class="form-group">
                                <label class="control-label">@localizer["CheckInNote"]</label>
                                <input type="text" name="checkInNote" class="form-control" placeholder="@localizer["CheckInNote"]" />
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-sign-in"></i> @localizer["CheckIn"]
                            </button>
                        }
                    }
                    else if (Model.UserCheckIn == null && !checkInWindowOpen && !adminBypassWindow)
                    {
                        <p class="text-muted"><i class="fa fa-clock-o"></i> @localizer["CheckInNotYetAvailable"]</p>
                    }
                    else if (Model.UserCheckIn != null && !Model.UserCheckIn.CheckOutTime.HasValue)
                    {
                        <p><strong>@localizer["CheckInTime"]:</strong> @Model.UserCheckIn.CheckInTime.TimeConverterToString(Model.Department)</p>
                        @using (Html.BeginForm("CheckOut", "Calendar", FormMethod.Post, new { area = "User" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="calendarItemId" value="@Model.CalendarItem.CalendarItemId" />
                            <div class="form-group">
                                <label class="control-label">@localizer["CheckOutNote"]</label>
                                <input type="text" name="checkOutNote" class="form-control" placeholder="@localizer["CheckOutNote"]" />
                            </div>
                            <button type="submit" class="btn btn-warning">
                                <i class="fa fa-sign-out"></i> @localizer["CheckOut"]
                            </button>
                        }
                    }
                    else if (Model.UserCheckIn != null && Model.UserCheckIn.CheckOutTime.HasValue)
                    {
                        <p><strong>@localizer["CheckInTime"]:</strong> @Model.UserCheckIn.CheckInTime.TimeConverterToString(Model.Department)</p>
                        <p><strong>@localizer["CheckOutTime"]:</strong> @Model.UserCheckIn.CheckOutTime.Value.TimeConverterToString(Model.Department)</p>
                        <p><strong>@localizer["Duration"]:</strong> @Model.UserCheckIn.GetDuration()?.ToString(@"h\h\ m\m")</p>
                    }
                </div>
            </div>
        </div>
    </div>
        }
    @* Attendance Check-Ins Table *@
    @if (Model.CheckIns != null && Model.CheckIns.Any())
    {
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox float-e-margins">
                    <div class="ibox-title">
                        <h5><i class="fa fa-list-alt"></i> @localizer["EventAttendanceReport"]</h5>
                        <div class="ibox-tools">
                            <span class="badge">@Model.CheckIns.Count</span>
                        </div>
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover no-margins">
                                <thead>
                                    <tr>
                                        <th>@commonLocalizer["Name"]</th>
                                        <th>@localizer["CheckInTime"]</th>
                                        <th>@localizer["CheckOutTime"]</th>
                                        <th>@localizer["Duration"]</th>
                                        <th>@localizer["CheckInNote"]</th>
                                        <th>@localizer["CheckOutNote"]</th>
                                        @if (Model.IsAdmin)
                                        {
                                            <th></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ci in Model.CheckIns)
                                    {
                                        var personName = Model.PersonnelNames?.FirstOrDefault(x => string.Equals(x.UserId, ci.UserId, StringComparison.OrdinalIgnoreCase));
                                        <tr>
                                            <td>
                                                @(personName?.Name ?? ci.UserId)
                                                @if (!string.IsNullOrWhiteSpace(ci.CheckInByUserId))
                                                {
                                                    var byName = Model.PersonnelNames?.FirstOrDefault(x => string.Equals(x.UserId, ci.CheckInByUserId, StringComparison.OrdinalIgnoreCase));
                                                    <br /><small class="text-muted">@localizer["CheckIn"] by @(byName?.Name ?? ci.CheckInByUserId)</small>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(ci.CheckOutByUserId))
                                                {
                                                    var byName = Model.PersonnelNames?.FirstOrDefault(x => string.Equals(x.UserId, ci.CheckOutByUserId, StringComparison.OrdinalIgnoreCase));
                                                    <br /><small class="text-muted">@localizer["CheckOut"] by @(byName?.Name ?? ci.CheckOutByUserId)</small>
                                                }
                                            </td>
                                            <td><small>@ci.CheckInTime.TimeConverterToString(Model.Department)</small></td>
                                            <td>
                                                @if (ci.CheckOutTime.HasValue)
                                                {
                                                    <small>@ci.CheckOutTime.Value.TimeConverterToString(Model.Department)</small>
                                                }
                                                else
                                                {
                                                    <span class="label label-info">@localizer["NotCheckedOut"]</span>
                                                }
                                            </td>
                                            <td>
                                                @if (ci.GetDuration() != null)
                                                {
                                                    @ci.GetDuration()?.ToString(@"h\h\ m\m")
                                                }
                                            </td>
                                            <td><small>@ci.CheckInNote</small></td>
                                            <td><small>@ci.CheckOutNote</small></td>
                                            @if (Model.IsAdmin)
                                            {
                                                <td class="text-right" style="white-space:nowrap;">
                                                    @if (!ci.CheckOutTime.HasValue)
                                                    {
                                                        @using (Html.BeginForm("AdminCheckOut", "Calendar", FormMethod.Post, new { area = "User", style = "display:inline;" }))
                                                        {
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="calendarItemId" value="@Model.CalendarItem.CalendarItemId" />
                                                            <input type="hidden" name="userId" value="@ci.UserId" />
                                                            <button type="submit" class="btn btn-xs btn-warning" title="@localizer["CheckOut"]">
                                                                <i class="fa fa-sign-out"></i>
                                                            </button>
                                                        }
                                                    }
                                                    <a href="@Url.Action("EditCheckIn", "Calendar", new { area = "User", checkInId = ci.CalendarItemCheckInId })"
                                                       class="btn btn-xs btn-default" title="@localizer["EditCheckInTimes"]">
                                                        <i class="fa fa-pencil"></i>
                                                    </a>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    @* Admin Check-In on Behalf — admins can always check in users, even after the event *@
    @if (Model.IsAdmin && Model.CalendarItem.Attendees != null && Model.CalendarItem.Attendees.Any())
    {
        var uncheckedAttendees = Model.CalendarItem.Attendees
            .Where(a => Model.CheckIns == null || !Model.CheckIns.Any(c => c.UserId == a.UserId))
            .ToList();
        if (uncheckedAttendees.Any())
        {
            <div class="row">
                <div class="col-lg-6">
                    <div class="ibox float-e-margins">
                        <div class="ibox-title">
                            <h5><i class="fa fa-user-plus"></i> @localizer["AdminCheckIn"]</h5>
                        </div>
                        <div class="ibox-content">
                            <p class="text-muted">@localizer["CheckInOnBehalf"]</p>
                            <div class="list-group">
                                @foreach (var attendee in uncheckedAttendees)
                                {
                                    var aName = Model.PersonnelNames?.FirstOrDefault(x => string.Equals(x.UserId, attendee.UserId, StringComparison.OrdinalIgnoreCase));
                                    @using (Html.BeginForm("AdminCheckIn", "Calendar", FormMethod.Post, new { area = "User", style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="calendarItemId" value="@Model.CalendarItem.CalendarItemId" />
                                        <input type="hidden" name="userId" value="@attendee.UserId" />
                                        <button type="submit" class="list-group-item list-group-item-action" style="cursor:pointer;">
                                            <i class="fa fa-sign-in text-primary"></i> @(aName?.Name ?? attendee.UserId)
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    } @* end CheckInType != Disabled *@
</div>
@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
            $.ajax({
                url: resgrid.absoluteBaseUrl + '/User/Calendar/GetMapDataForItem?calendarItemId=@Model.CalendarItem.CalendarItemId',
                contentType: 'application/json; charset=utf-8',
                type: 'GET'
            }).done(function (result) {
                var data = result;
                if (data.wasSuccess === true) {
                    // map initialization will go here
                }
            });
        });
    </script>
}
