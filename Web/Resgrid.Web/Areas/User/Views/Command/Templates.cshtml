@using Resgrid.Model.CommandBoards
@using System.Linq
@model IReadOnlyList<CommandBoardTemplate>
@{
	ViewBag.Title = "Resgrid | Command Board Examples";
	var categories = Model.Select(template => template.Category).Distinct().ToList();
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-8">
		<h2>Command Board Examples</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">Home</a>
			</li>
			<li>
				<a asp-controller="Command" asp-action="Index" asp-route-area="User">Command Boards</a>
			</li>
			<li class="active">
				<strong>Examples</strong>
			</li>
		</ol>
	</div>
</div>

<div class="wrapper wrapper-content">
	<div class="row">
		<div class="col-lg-12">
			<div class="ibox float-e-margins">
				<div class="ibox-title">
					<h5>Choose a starting layout</h5>
					<div class="ibox-tools">
						<a class="btn btn-white btn-sm" asp-controller="Command" asp-action="New" asp-route-area="User">
							<i class="fa fa-file-o"></i> Start from Blank
						</a>
					</div>
				</div>
				<div class="ibox-content">
					<p>
						These examples pre-fill the board name, description, timer and lanes. You can rename or remove
						lanes, add your own, and adjust requirements before saving. Suggested unit types and personnel
						roles are matched to your department by name; nothing is saved until you create the board.
					</p>

					<div class="row" style="margin-bottom: 18px;">
						<div class="col-sm-8 col-md-6">
							<div class="input-group">
								<span class="input-group-addon"><i class="fa fa-search"></i></span>
								<input type="text" id="templateSearch" class="form-control" placeholder="Search examples, lanes or disciplines..." autocomplete="off" />
							</div>
						</div>
						<div class="col-sm-4 col-md-3">
							<select id="templateCategory" class="form-control">
								<option value="">All categories</option>
								@foreach (var category in categories)
								{
									<option value="@category.ToLowerInvariant()">@category</option>
								}
							</select>
						</div>
					</div>

					<div class="row" id="templateGrid">
						@foreach (var template in Model)
						{
							<div class="col-md-6 col-lg-4 template-card"
								 data-search="@template.SearchText"
								 data-category="@template.Category.ToLowerInvariant()"
								 style="margin-bottom: 16px;">
								<div class="ibox" style="margin-bottom: 0;">
									<div class="ibox-content" style="min-height: 290px;">
										<div class="clearfix" style="margin-bottom: 6px;">
											<strong style="font-size: 16px;">@template.Name</strong>
											<span class="label label-primary pull-right">@template.Category</span>
										</div>
										<p class="text-muted" style="min-height: 56px;">@template.Description</p>

										<div style="min-height: 90px; margin-bottom: 10px;">
											@foreach (var lane in template.Lanes)
											{
												<span class="label label-default"
													  title="@lane.Description"
													  style="display:inline-block; margin: 0 4px 5px 0; font-weight: normal;">
													@lane.Name
												</span>
											}
										</div>

										<div class="clearfix">
											<small class="text-muted pull-left" style="line-height: 30px;">
												@template.LaneCount lanes
												@if (template.Timer)
												{
													<span> &middot; @template.TimerMinutes-minute timer</span>
												}
											</small>
											<a class="btn btn-primary btn-sm pull-right"
											   asp-controller="Command" asp-action="New" asp-route-area="User"
											   asp-route-templateId="@template.Id">
												Use this example
											</a>
										</div>
									</div>
								</div>
							</div>
						}
					</div>

					<div id="noTemplateResults" class="alert alert-warning" style="display:none;">
						No examples match those filters. Try another search or
						<a asp-controller="Command" asp-action="New" asp-route-area="User">start from blank</a>.
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts
{
	<script>
		(function () {
			var search = document.getElementById('templateSearch');
			var category = document.getElementById('templateCategory');
			var cards = Array.prototype.slice.call(document.querySelectorAll('#templateGrid .template-card'));
			var noResults = document.getElementById('noTemplateResults');

			function applyFilter() {
				var query = (search.value || '').toLowerCase().trim();
				var selectedCategory = (category.value || '').toLowerCase();
				var terms = query.length ? query.split(/[\s,]+/) : [];
				var visible = 0;

				cards.forEach(function (card) {
					var haystack = card.getAttribute('data-search') || '';
					var cardCategory = card.getAttribute('data-category') || '';
					var matches = (!selectedCategory || cardCategory === selectedCategory) &&
						terms.every(function (term) { return haystack.indexOf(term) !== -1; });

					card.style.display = matches ? '' : 'none';
					if (matches) { visible++; }
				});

				noResults.style.display = visible === 0 ? '' : 'none';
			}

			search.addEventListener('input', applyFilter);
			category.addEventListener('change', applyFilter);
		})();
	</script>
}
