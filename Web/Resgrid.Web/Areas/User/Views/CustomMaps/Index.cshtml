@model Resgrid.Web.Areas.User.Models.CustomMaps.CustomMapIndexView
@using Resgrid.Model
@{
    ViewBag.Title = "Resgrid | Custom Maps";
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>Custom Maps</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">Home</a>
            </li>
            <li class="active">
                <strong>Custom Maps</strong>
            </li>
        </ol>
    </div>
    <div class="col-sm-8">
        <div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
            <a class="btn btn-success" asp-controller="CustomMaps" asp-action="New" asp-route-area="User">New Custom Map</a>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <ul class="nav nav-tabs" style="margin-bottom:15px;">
                        <li class="@(Model.FilterType == null ? "active" : "")">
                            <a asp-controller="CustomMaps" asp-action="Index" asp-route-area="User">All</a>
                        </li>
                        <li class="@(Model.FilterType == CustomMapType.Indoor ? "active" : "")">
                            <a asp-controller="CustomMaps" asp-action="Index" asp-route-area="User" asp-route-type="0">Indoor</a>
                        </li>
                        <li class="@(Model.FilterType == CustomMapType.Outdoor ? "active" : "")">
                            <a asp-controller="CustomMaps" asp-action="Index" asp-route-area="User" asp-route-type="1">Outdoor</a>
                        </li>
                        <li class="@(Model.FilterType == CustomMapType.Event ? "active" : "")">
                            <a asp-controller="CustomMaps" asp-action="Index" asp-route-area="User" asp-route-type="2">Event</a>
                        </li>
                        <li class="@(Model.FilterType == CustomMapType.Custom ? "active" : "")">
                            <a asp-controller="CustomMaps" asp-action="Index" asp-route-area="User" asp-route-type="3">Custom</a>
                        </li>
                    </ul>
                    <div class="table-responsive">
                        <table class="table table-striped" id="customMapsTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Created</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Maps != null)
                                {
                                    foreach (var map in Model.Maps)
                                    {
                                        <tr>
                                            <td>@map.Name</td>
                                            <td>@((CustomMapType)map.MapType)</td>
                                            <td>@map.Description</td>
                                            <td>@map.AddedOn.ToString("g")</td>
                                            <td style="text-align:right;">
                                                <a class="btn btn-primary btn-xs" asp-controller="CustomMaps" asp-action="Layers" asp-route-id="@map.IndoorMapId" asp-route-area="User"><i class="fa fa-layer-group"></i> Layers</a>
                                                <a class="btn btn-warning btn-xs" asp-controller="CustomMaps" asp-action="Import" asp-route-id="@map.IndoorMapId" asp-route-area="User"><i class="fa fa-upload"></i> Import</a>
                                                <a class="btn btn-info btn-xs" asp-controller="CustomMaps" asp-action="Edit" asp-route-id="@map.IndoorMapId" asp-route-area="User"><i class="fa fa-pencil"></i> Edit</a>
                                                <a class="btn btn-danger btn-xs" asp-controller="CustomMaps" asp-action="Delete" asp-route-id="@map.IndoorMapId" asp-route-area="User" onclick="return confirm('Are you sure you want to delete this map?');"><i class="fa fa-trash"></i> Delete</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/app/internal/custommaps/resgrid.custommaps.index.js" asp-append-version="true"></script>
}
