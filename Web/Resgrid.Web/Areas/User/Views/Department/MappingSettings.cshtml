@model Resgrid.Web.Areas.User.Models.Departments.MappingSettingsView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Department.Department> localizer
@{
    ViewBag.Title = "Resgrid | " + @localizer["MappingSettingsHeader"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["MappingSettingsHeader"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li>
                <a asp-controller="Department" asp-action="Settings" asp-route-area="User">@localizer["DepartmentSettingsHeader"]</a>
            </li>
            <li class="active">
                <strong>@localizer["MappingSettingsHeader"]</strong>
            </li>
        </ol>
    </div>
</div>

<form role="form" class="form-horizontal" asp-controller="Department" asp-action="MappingSettings" asp-route-area="User" method="post">
    <div class="row">
        <div class="col-xs-12">
            <div class="wrapper wrapper-content">
                <div class="ibox float-e-margins">
                    <div class="ibox-content">
                        <div class="form-horizontal">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="text-danger"></div>

                            @if (Model.SaveSuccess.GetValueOrDefault())
				            {
                              <div class="alert alert-success">
                                @localizer["SavedMappingSettings"]
                              </div>
				            }

                            <h3>@localizer["MappingSettingsPersonnelHeader"]</h3>
                            <div class="form-group">
                                <label class="col-sm-3 control-label">@localizer["MappingSettingsPersonnelAllowOverwriteLabel"]</label>
                                <div class="col-sm-6">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <input type="checkbox" asp-for="PersonnelAllowStatusWithNoLocationToOverwrite">
                                        </div>
                                    </div>
                                    <span class="help-block m-b-none">@localizer["PersonnelAllowOverwriteHelp"]</span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-sm-3 control-label">@localizer["MappingSettingsPersonnelTTLLabel"]</label>
                                <div class="col-sm-6">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <input type="number" asp-for="PersonnelLocationTTL" min="0" max="1440">
                                        </div>
                                    </div>
                                    <span class="help-block m-b-none">@localizer["PersonnelTTLHelp"]</span>
                                </div>
                            </div>
                            
                            <h3>@localizer["MappingSettingsUnitsHeader"]</h3>
                            <div class="form-group">
                                <label class="col-sm-3 control-label">@localizer["MappingSettingsUnitAllowOverwriteLabel"]</label>
                                <div class="col-sm-6">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <input type="checkbox" asp-for="UnitAllowStatusWithNoLocationToOverwrite">
                                        </div>
                                    </div>
                                    <span class="help-block m-b-none">@localizer["UnitAllowOverwriteHelp"]</span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-sm-3 control-label">@localizer["MappingSettingsUnitTTLLabel"]</label>
                                <div class="col-sm-6">
                                    <div class="row">
                                        <div class="col-sm-6">
                                            <input type="number" asp-for="UnitLocationTTL" min="0" max="1440">
                                        </div>
                                    </div>
                                    <span class="help-block m-b-none">@localizer["UnitTTLHelp"]</span>
                                </div>
                            </div>

							<h3>Department Mapbox Override</h3>
							<div class="form-group">
								<label class="col-sm-3 control-label">Use Department Mapbox Map</label>
								<div class="col-sm-6">
									<div class="row">
										<div class="col-sm-6">
											<input type="checkbox" asp-for="UseMapboxOverride">
										</div>
									</div>
									<span class="help-block m-b-none">When enabled, this department's Mapbox style and public token override the system map mode for the department website views and authenticated mobile/API clients, even when the system stays on Leaflet.</span>
								</div>
							</div>
							<div class="form-group">
								<label class="col-sm-3 control-label">Mapbox Style Url</label>
								<div class="col-sm-6">
									<input type="text" class="form-control" asp-for="MapboxStyleUrl" placeholder="mapbox://styles/username/styleid">
									<span class="help-block m-b-none">Supported values are `mapbox://styles/...` or `https://api.mapbox.com/styles/v1/...`.</span>
								</div>
							</div>
							<div class="form-group">
								<label class="col-sm-3 control-label">Mapbox Public Access Token</label>
								<div class="col-sm-6">
									<input type="text" class="form-control" asp-for="MapboxAccessToken" placeholder="pk.ey...">
									<span class="help-block m-b-none">Use a public Mapbox token intended for website and mobile client-side map rendering for this department.</span>
								</div>
							</div>
 
                            <div class="form-group">
                                <div class="col-sm-4 col-sm-offset-2">
                                    <a class="btn btn-white" asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Cancel"]</a>
                                    <button class="btn btn-primary" type="submit">@commonLocalizer["Save"]</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts
{

}
