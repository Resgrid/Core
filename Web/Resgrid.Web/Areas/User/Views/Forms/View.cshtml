@using Resgrid.Model
@model Resgrid.WebCore.Areas.User.Models.Forms.ViewFormModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Forms.Forms> localizer
@{
  ViewBag.Title = "Resgrid | " + localizer["ViewFormPageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
  <div class="col-sm-4">
    <h2>@localizer["ViewFormHeading"]</h2>
    <ol class="breadcrumb">
      <li>
        <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
      </li>
      <li>
        <a asp-controller="Forms" asp-action="Index" asp-route-area="User">@localizer["FormsHeading"]</a>
      </li>
      <li class="active">
        <strong>@localizer["ViewFormHeading"]</strong>
      </li>
    </ol>
  </div>
</div>

<div class="row">
  <div class="col-xs-12">
    <div class="wrapper wrapper-content">
      <div class="ibox float-e-margins">
        <div class="ibox-content">
		  <div class="form-horizontal">
		    <div class="form-group">
		      <label class="col-sm-2 control-label required">
		        @localizer["FormNameLabel"]
		      </label>
		      <div class="col-sm-6">
		        @Model.Form.Name
		      </div>
		    </div>
		    <div class="form-group">
		      <label class="col-sm-2 control-label required">
		        @localizer["FormTypeLabel"]
		      </label>
		      <div class="col-sm-3">
		        @if (Model.Form.Type == 0)
				{
		          <span>@localizer["NewCallFormType"]</span>
				}
		      </div>
		    </div>
		    <div class="form-group">
		      <label class="col-sm-2 control-label required">
		        @localizer["FormLabel"]
		      </label>
		      <div class="col-sm-9">
		        <div id="fb-template"></div>
		      </div>
		    </div>
		  </div>
        </div>
      </div>
    </div>
  </div>
</div>


@section Scripts
{
  <script src="@Url.Content("~/lib/formBuilder/dist/form-render.min.js")" type="text/javascript"></script>
  <script>
	jQuery(function ($) {
	  $('#fb-template').formRender({
        dataType: 'json',
		formData: '@Html.Raw(Model.Form.Data)'
	  });
	});
  </script>
}
