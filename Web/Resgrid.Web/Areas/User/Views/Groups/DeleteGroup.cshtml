@model Resgrid.Web.Areas.User.Models.Groups.DeleteGroupView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Groups.Groups> localizer
@{
    ViewBag.Title = "Resgrid | " + localizer["DeleteGroupPageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["DeleteGroupHeading"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
            </li>
            <li>
                <a asp-controller="Groups" asp-action="Index" asp-route-area="User">@localizer["GroupsHeading"]</a>
            </li>
            <li class="active">
                <strong>@localizer["DeleteGroupHeading"]</strong>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <form id="edit_user" class="form-horizontal" role="form" asp-controller="Groups" asp-action="DeleteGroup" asp-route-area="User" method="post">

                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Group.DepartmentGroupId)
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class='page-header'>
                            <h3>
                                @localizer["DeleteGroupHeading"] @Model.Group.Name
                            </h3>
                        </div>
                        <div class="alert alert-error">
                            <strong>@localizer["DeleteGroupConfirmQuestion"]</strong> @localizer["DeleteGroupWarning"]
                            <br />
                        </div>
                        @if (Model.UserCount > 0)
                        {
                            <hr />
                            <div class="alert alert-danger">
                                @localizer["DeleteGroupActiveUsersWarning"]
                            </div>
                        }

                        @if (Model.ChildGroupCount > 0)
                        {
                            <hr />
                            <div class='alert alert-danger'>
                                @localizer["DeleteGroupChildGroupsWarning"]
                            </div>
                        }

                        @if (Model.UnitsCount > 0)
                        {
                            <hr />
                            <div class='alert alert-danger'>
                                @localizer["DeleteGroupUnitsWarning"]
                            </div>
                        }

                        @if (Model.ShiftsCount > 0)
                        {
                            <hr />
                            <div class='alert alert-danger'>
                                @localizer["DeleteGroupShiftsWarning"]
                            </div>
                        }

                        @if (Model.UserCount == 0 && Model.ChildGroupCount == 0 && Model.UnitsCount == 0 && Model.ShiftsCount == 0)
                        {
                            <hr />
                            <div class='alert alert-warning'>
                                <i class='picons-16-basic1-104'></i>@localizer["DeleteGroupCheckboxHint"]
                            </div>

                            <div class="alert alert-error">
                                @localizer["DeleteGroupPermanentWarning"]
                                <br /><br />
                                <strong>@localizer["DeleteGroupDataDeleted"]</strong>
                                <ul>
                                    <li>@localizer["DeleteGroupDataGroupData"]</li>
                                    <li>@localizer["DeleteGroupDataPersonnelMemberships"]</li>
                                    <li>@localizer["DeleteGroupDataUnitMemberships"]</li>
                                    <li>@localizer["DeleteGroupDataInventory"]</li>
                                    <li>@localizer["DeleteGroupDataShiftData"]</li>
                                </ul>
                            </div>

                            <div class="form-group">
                                <label class="col-sm-2 control-label">@localizer["ConfirmDeleteLabel"]</label>
                                <div class="col-sm-10">
                                    <input type="checkbox" asp-for="AreYouSure">
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="col-sm-4 col-sm-offset-2">
                                    <a class="btn btn-white" asp-controller="Groups" asp-action="Index" asp-route-area="User">@commonLocalizer["Cancel"]</a>
                                    <button class="btn btn-primary" type="submit">@localizer["DeleteGroupButton"]</button>
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{

}
