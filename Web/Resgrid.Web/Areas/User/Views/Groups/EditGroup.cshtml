@using Resgrid.Model
@model Resgrid.Web.Areas.User.Models.Groups.EditGroupView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Groups.Groups> localizer
@{
    ViewBag.Title = "Resgrid | " + localizer["EditGroupPageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["EditGroupHeading"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
            </li>
            <li>
                <a asp-controller="Groups" asp-action="Index" asp-route-area="User">@localizer["GroupsHeading"]</a>
            </li>
            <li class="active">
                <strong>@localizer["EditGroupHeading"]</strong>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <form class="form-horizontal" role="form" asp-controller="Groups" asp-action="EditGroup" asp-route-area="User" method="post">

                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.EditGroup.DepartmentGroupId)
                        @Html.HiddenFor(m => m.EditGroup.Type)
                        @Html.HiddenFor(m => m.PrinterId)
                        @Html.HiddenFor(m => m.PrinterApiKey)

                        <div asp-validation-summary="All" class="text-danger"></div>
                        @if (!String.IsNullOrEmpty(Model.Message))
                        {
                            <div class="alert alert-success">
                                @Model.Message
                            </div>
                        }

                        <div class="form-group">
                            <label class="col-sm-2 control-label">@localizer["GroupType"]</label>
                            <div class="col-sm-10">
                                <div class="row">
                                    <div class="col-sm-12">
                                        <label class="col-sm-2 control-label" style="padding-top:0px;">@localizer["OrganizationalGroup"]</label>
                                        @if (Model.EditGroup.Type.HasValue && Model.EditGroup.Type.Value == (int)DepartmentGroupTypes.Station)
                                        {
                                            <input type="radio" value="1" id="groupTypeOrgRadio" title="@localizer["OrganizationalGroup"]" disabled="">
                                        }
                                        else
                                        {
                                            <input type="radio" value="1" id="groupTypeOrgRadio" title="@localizer["OrganizationalGroup"]" checked="checked" disabled="">
                                        }
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-12">
                                        <label class="col-sm-2 control-label" style="padding-top:0px;">@localizer["StationGroup"]</label>
                                        @if (Model.EditGroup.Type.HasValue && Model.EditGroup.Type.Value == (int)DepartmentGroupTypes.Station)
                                        {
                                            <input type="radio" value="2" title="@localizer["StationGroup"]" checked="checked" disabled="">
                                        }
                                        else
                                        {
                                            <input type="radio" value="2" title="@localizer["StationGroup"]" disabled="">
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label">@localizer["GroupName"]</label>
                            <div class="col-sm-10"><input type="text" asp-for="EditGroup.Name" class="form-control" /></div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label">@localizer["ParentGroup"]</label>
                            <div class="col-sm-10">@Html.DropDownListFor(m => m.EditGroup.ParentDepartmentGroupId, Model.StationGroups)</div>
                        </div>
                        <div class="form-group" id="StationAddress">
                            <label class="col-sm-2 control-label">
                                @localizer["StationAddress"]
                            </label>
                            <div class="col-sm-10">
                                <div class="well">
                                    <span>@localizer["StationAddressDescription"] <a href="https://what3words.com/about/" target="_blank">what3words address.</a></span>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label required">
                                            @localizer["Street"]
                                        </label>
                                        <div class="col-sm-10">
                                            @Html.TextBoxFor(m => m.Address1, new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label required">
                                            @localizer["City"]
                                        </label>
                                        <div class="col-sm-10">
                                            @Html.TextBoxFor(m => m.City, new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label required">
                                            @localizer["StateProvince"]
                                        </label>
                                        <div class="col-sm-10">
                                            @Html.TextBoxFor(m => m.State, new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label required">
                                            @localizer["ZipPostalCode"]
                                        </label>
                                        <div class="col-sm-10">
                                            @Html.TextBoxFor(m => m.PostalCode, new { @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label required">
                                            @localizer["Country"]
                                        </label>
                                        <div class="col-sm-10">
                                            @Html.DropDownListFor(m => m.Country, new SelectList(Countries.CountryNames), new { @class = "form-control", style = "width: 300px" })
                                        </div>
                                    </div>
                                    <div style="text-align: center;">
                                        <h4>@localizer["Or"]</h4>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">
                                            @localizer["GpsCoordinates"]
                                        </label>
                                        <div class="controls">
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(m => m.Latitude, new { @class = "form-control" })
                                                <span class="help-inline">@localizer["LatitudeHint"]</span>
                                            </div>
                                            <div class="col-md-4">
                                                @Html.TextBoxFor(m => m.Longitude, new { @class = "form-control" })
                                                <span class="help-inline">@localizer["LongitudeHint"]</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="text-align: center;">
                                        <h4>@localizer["Or"]</h4>
                                    </div>
                                    <div class="form-group">
                                        <label class="control-label">
                                            @localizer["What3WordsAddress"]
                                        </label>
                                        <div class="controls">
                                            <div class="col-md-8">
                                                @Html.TextBoxFor(m => m.What3Word, new { @class = "form-control", @style = "width:250px;", autocomplete = "off", placeholder = "what.three.words", tabindex = "8" })
                                                <span class="help-inline">@localizer["What3WordsHint"]</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label required">
                                <a href="https://www.printnode.com">PrintNode</a> @localizer["PrintNodePrinter"]
                            </label>
                            <div class="col-sm-10">
                                <div class="row">
                                    <div class="col-xs-4">
                                        <a class="btn btn-sm btn-inverse" href="#selectPrinterModal" data-toggle="modal" id="selectPrinter">@localizer["SelectPrinter"]</a>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-10">
                                        <p><a href="https://www.printnode.com">PrintNode</a> @localizer["PrintNodeDescription"]</p>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-4">
                                        @Html.TextBoxFor(m => m.PrinterName, new { @class = "form-control" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label">@localizer["PrintCallsToPrinter"]</label>
                            <div class="col-sm-10">
                                <div class="row">
                                    <div class="col-sm-10">
                                        <input type="checkbox" asp-for="EditGroup.DispatchToPrinter">
                                    </div>
                                </div>
                                <span class="help-block m-b-none">@localizer["PrintCallsToPrinterHint"]</span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-10 col-md-offset-2">
                                <p>@localizer["UsersOneGroupNote"]</p>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label required">
                                @localizer["GroupAdmins"]
                            </label>
                            <div class="col-sm-10">
                                <div class="row">
                                    <div class="col-xs-4"><select id="groupAdmins" name="groupAdmins" multiple="multiple" style="width: 100%;"></select></div>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label required">
                                @localizer["GroupUsers"]
                            </label>
                            <div class="col-sm-10">
                                <select id="groupUsers" name="groupUsers" multiple="multiple" style="width: 100%;"></select>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="col-sm-4 col-sm-offset-2">
                                <a class="btn btn-white" asp-controller="Groups" asp-action="Index" asp-route-area="User">@commonLocalizer["Cancel"]</a>
                                <button class="btn btn-primary" type="submit">@localizer["SaveGroup"]</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="selectPrinterModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="exampleModalLabel">@localizer["SelectPrinter"]</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="assignment-name" class="control-label">@localizer["ApiKey"]</label>
                    <input type="text" class="form-control" id="apiKey">
                </div>
                <div class="form-group">
                    <button type="button" class="btn btn-inverse" id="getPrintersButton">@localizer["GetPrinters"]</button>
                </div>
                <table class="table table-bordered table-striped table-hover data-table">
                    <thead>
                        <tr>
                            <th>@localizer["Printer"]</th>
                            <th>&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody id="printersTableBody"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">@localizer["Close"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
    {
    @if (Model.EditGroup.Type.HasValue && Model.EditGroup.Type.Value == (int)DepartmentGroupTypes.Station)
    {
        <script>
            $(document).ready(function () {
                $("#ParentFields").hide();
                $("#StationAddress").show();
            });
        </script>
    }
    else
    {
        <script>
            $(document).ready(function () {
                $("#ParentFields").show();
                $("#StationAddress").hide();
            });
        </script>
    }

    <script src="~/js/app/internal/groups/resgrid.groups.editgroup.js"></script>
}
