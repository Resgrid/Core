@using Resgrid.Model
@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Groups.DepartmentGroupsModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Groups.Groups> localizer
@{
    ViewBag.Title = "Resgrid | " + localizer["IndexPageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>
            <h1>@localizer["GroupsHeading"]</h1>
        </h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
            </li>
            <li class="active">
                <strong>@localizer["GroupsHeading"]</strong>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>@localizer["GroupsHeading"]</h5>
                    <div class="ibox-tools">
                        @if (Model.CanAddNewGroup)
                        {
                            <div class="buttons-actions">
                                <a title="@localizer["AddNewGroupTitle"]" class="btn btn-success" asp-controller="Groups" asp-action="NewGroup" asp-route-area="User">@localizer["AddNewGroup"]</a>
                            </div>
                        }
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>
                                        @localizer["GroupName"]
                                    </th>
                                    <th>
                                        @commonLocalizer["Type"]
                                    </th>
                                    <th>
                                        @localizer["Parent"]
                                    </th>
                                    <th>
                                        @localizer["DispatchEmail"]
                                    </th>
                                    <th>
                                        @localizer["MessageEmail"]
                                    </th>
                                    <th>
                                        @localizer["Members"]
                                    </th>
                                    <th class="span1">
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in Model.Groups)
                                {
                                    <tr>
                                        <td>
                                            @g.Name
                                        </td>
                                        <td>
                                            @if (g.Type == null || g.Type == (int)DepartmentGroupTypes.Orginizational)
                                            {
                                                @Html.Raw(localizer["Organizational"].Value)
                                            }
                                            else
                                            {
                                                @Html.Raw(localizer["Station"].Value)
                                            }
                                        </td>
                                        <td>
                                            @if (g.Parent == null)
                                            {
                                                @Html.Raw(localizer["None"].Value)
                                            }
                                            else
                                            {
                                                @Html.Raw(g.Parent.Name)
                                            }
                                        </td>
                                        <td>
                                            @g.DispatchEmail@@@Resgrid.Config.InboundEmailConfig.GroupsDomain
                                        </td>
                                        <td>
                                            @g.MessageEmail@@@Resgrid.Config.InboundEmailConfig.GroupMessageDomain
                                        </td>
                                        <td>
                                            @g.Members.Count
                                        </td>
                                        <td>
                                            @if (ClaimsAuthorizationHelper.IsUserDepartmentOrGroupAdmin(g.DepartmentGroupId))
                                            {
                                                <a class="btn btn-xs btn-primary" asp-controller="Groups" asp-action="EditGroup" asp-route-area="User" asp-route-departmentGroupId="@g.DepartmentGroupId">@commonLocalizer["Edit"]</a>

                                                @if (g.Type == (int)DepartmentGroupTypes.Station)
                                                {
                                                    <a class="btn btn-xs btn-info" asp-controller="Groups" asp-action="Geofence" asp-route-area="User" asp-route-departmentGroupId="@g.DepartmentGroupId">@localizer["Geofence"]</a>
                                                }
                                                <a class="btn btn-xs btn-danger" asp-controller="Groups" asp-action="DeleteGroup" asp-route-area="User" asp-route-departmentGroupId="@g.DepartmentGroupId" data-confirm="WARNING: This will permanently delete this group and all units, Shift Groups, etc attached to this group. Are you sure you want to delete the group @g.Name?" rel="nofollow">@commonLocalizer["Delete"]</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
    {

}
