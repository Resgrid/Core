@model Resgrid.Web.Areas.User.Models.IndoorMaps.IndoorMapFloorsView
@{
    ViewBag.Title = "Resgrid | Floors - " + Model.IndoorMap.Name;
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>Floors - @Model.IndoorMap.Name</h2>
        <ol class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">Home</a></li>
            <li><a asp-controller="IndoorMaps" asp-action="Index" asp-route-area="User">Indoor Maps</a></li>
            <li class="active"><strong>Floors</strong></li>
        </ol>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Add Floor</h5>
                </div>
                <div class="ibox-content">
                    <form asp-action="NewFloor" asp-controller="IndoorMaps" asp-route-area="User" method="post" enctype="multipart/form-data" class="form-horizontal">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="indoorMapId" value="@Model.IndoorMap.IndoorMapId" />
                        <div class="form-group">
                            <label class="col-sm-2 control-label">Floor Name</label>
                            <div class="col-sm-4">
                                <input type="text" class="form-control" name="name" placeholder="e.g. Floor 1, Basement, Roof" required />
                            </div>
                            <label class="col-sm-2 control-label">Order</label>
                            <div class="col-sm-2">
                                <input type="number" class="form-control" name="floorOrder" value="0" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-sm-2 control-label">Floor Plan Image</label>
                            <div class="col-sm-6">
                                <input type="file" name="floorImage" accept="image/*" />
                            </div>
                            <div class="col-sm-2">
                                <button class="btn btn-primary" type="submit">Add Floor</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>Floors</h5>
                </div>
                <div class="ibox-content">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Order</th>
                                    <th>Name</th>
                                    <th>Has Image</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Floors != null)
                                {
                                    foreach (var floor in Model.Floors)
                                    {
                                        <tr>
                                            <td>@floor.FloorOrder</td>
                                            <td>@floor.Name</td>
                                            <td>@(floor.ImageData != null ? "Yes" : "No")</td>
                                            <td style="text-align:right;">
                                                <a class="btn btn-primary btn-xs" asp-controller="IndoorMaps" asp-action="ZoneEditor" asp-route-id="@floor.IndoorMapFloorId" asp-route-area="User"><i class="fa fa-pencil"></i> Zone Editor</a>
                                                <a class="btn btn-danger btn-xs" asp-controller="IndoorMaps" asp-action="DeleteFloor" asp-route-id="@floor.IndoorMapFloorId" asp-route-area="User" onclick="return confirm('Delete this floor?');"><i class="fa fa-trash"></i> Delete</a>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
