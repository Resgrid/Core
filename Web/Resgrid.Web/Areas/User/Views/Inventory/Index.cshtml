@using Resgrid.Model
@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Units.UnitsIndexView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Inventory.Inventory> localizer
@{
    ViewBag.Title = "Resgrid | " + commonLocalizer["InventoryModule"];
}

<style>
    .k-grid-content {
        padding-bottom: 150px;
    }
</style>

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@commonLocalizer["InventoryModule"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li class="active">
                <strong>@commonLocalizer["InventoryModule"]</strong>
            </li>
        </ol>
    </div>
    <div class="col-sm-8">
        <div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
            @if (ClaimsAuthorizationHelper.CanAdjustInventory())
            {
                <a title="@localizer["AdjustInventory"]" class="btn btn-success" href="@Url.Action("Adjust", "Inventory", new {area = "User"})">@localizer["AdjustInventory"]</a>
            }
            <a title="@localizer["ViewHistory"]" class="btn btn-primary" href="@Url.Action("History", "Inventory", new {area = "User"})">@localizer["ViewHistory"]</a>
            @if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
            {
                <a title="@localizer["ManageTypes"]" class="btn btn-info" href="@Url.Action("ManageTypes", "Inventory", new {area = "User"})">@localizer["ManageTypes"]</a>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <table id="inventoryIndexList" class="table table-striped table-bordered" width="100%"></table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script type="text/javascript">
        var inventoryIndexStrings = {
            name: '@Html.Raw(commonLocalizer["Name"].Value)',
            group: '@Html.Raw(localizer["Group"].Value)',
            unit: '@Html.Raw(localizer["Unit"].Value)',
            count: '@Html.Raw(localizer["Amount"].Value)'
        };
    </script>
    <script src="~/js/app/internal/inventory/resgrid.inventory.index.js" type="text/javascript"></script>
}
