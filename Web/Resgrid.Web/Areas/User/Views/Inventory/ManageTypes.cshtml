@using Resgrid.Model
@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Units.UnitsIndexView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Inventory.Inventory> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["InventoryTypesHeader"];
}

<style>
	.k-grid-content {
		padding-bottom: 150px;
	}
</style>

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["InventoryTypesHeader"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
			</li>
			<li>
				<a asp-controller="Inventory" asp-action="Index" asp-route-area="User">@commonLocalizer["InventoryModule"]</a>
			</li>
			<li class="active">
				<strong>@localizer["InventoryTypesHeader"]</strong>
			</li>
		</ol>
	</div>
	<div class="col-sm-8">
		<div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
			<a title="@localizer["AddType"]" class="btn btn-success" href="@Url.Action("AddType", "Inventory", new {area = "User"})">@localizer["AddType"]</a>
		</div>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
		<div class="wrapper wrapper-content">
			<div class="ibox float-e-margins">
				<div class="ibox-content">
					<table id="typesIndexList" class="table table-striped table-bordered" width="100%"></table>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts
{
	<script type="text/javascript">
		var inventoryTypesStrings = {
			name: '@Html.Raw(commonLocalizer["Name"].Value)',
			expiresDays: '@Html.Raw(localizer["ItemExpiresDays"].Value)',
			actions: '@Html.Raw(commonLocalizer["Actions"].Value)',
			edit: '@Html.Raw(localizer["Edit"].Value)',
			delete: '@Html.Raw(commonLocalizer["Delete"].Value)'
		};
	</script>
	<script src="~/js/app/internal/inventory/resgrid.inventory.manageTypes.js" type="text/javascript"></script>
}
