@using Resgrid.Model.Helpers
@model Resgrid.Web.Areas.User.Models.Inventory.ViewEntryView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Inventory.Inventory> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["ViewInventoryEntryHeader"];
}
@section Styles
{

}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["ViewInventoryEntryHeader"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
			</li>
			<li>
				<a asp-controller="Inventory" asp-action="Index" asp-route-area="User">@commonLocalizer["InventoryModule"]</a>
			</li>
			<li>
				<a asp-controller="Inventory" asp-action="History" asp-route-area="User">@localizer["InventoryHistoryHeader"]</a>
			</li>
			<li class="active">
				<strong>@localizer["ViewInventoryEntryHeader"]</strong>
			</li>
		</ol>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
			<div class="wrapper wrapper-content animated fadeInUp">
				<div class="ibox">
					<div class="ibox-content">
						<div class="row">
							<div class="col-lg-12">
								<div class="m-b-md">
									<h2>@Model.Inventory.Type.Type</h2>
								</div>
								<dl class="dl-horizontal">
									<dt>@commonLocalizer["Status"]:</dt>
									<dd><span class="label label-primary">@localizer["Active"]</span></dd>
								</dl>
							</div>
						</div>
						<div class="row">
							<div class="col-lg-5">
								<dl class="dl-horizontal">

									<dt>@localizer["CreatedBy"]:</dt>
									<dd></dd>
									<dt>@localizer["Group"]:</dt>
									<dd> @if (Model.Inventory.Group != null)
									{
										@Html.Raw(Model.Inventory.Group.Name)
									}
									else
									{
										<span>@localizer["NoGroup"]</span>
									}</dd>
									<dt>@localizer["Unit"]:</dt>
									<dd>@if (Model.Inventory.Unit != null)
									{
										@Html.Raw(Model.Inventory.Unit.Name)
									}
									else
									{
										<span>@localizer["NoUnit"]</span>
									}</dd>
									<dt>@localizer["Amount"]:</dt>
									<dd>@Model.Inventory.Amount</dd>
								</dl>
							</div>
							<div class="col-lg-7" id="cluster_info">
								<dl class="dl-horizontal">

									<dt>@localizer["AddedOn"]:</dt>
									<dd>@Model.Inventory.TimeStamp.FormatForDepartment(Model.Department)</dd>
									<dt>@localizer["BatchSerial"]:</dt>
									<dd>@Model.Inventory.Batch</dd>
									<dt>@commonLocalizer["Location"]:</dt>
									<dd>@Model.Inventory.Location</dd>
								</dl>
							</div>
						</div>
						<div class="row">
							<div class="col-lg-12">
								<p>@Html.Raw(Model.Inventory.Note)</p>
							</div>
						</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts
{

}
