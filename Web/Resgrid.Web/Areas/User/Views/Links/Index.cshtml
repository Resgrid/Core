@using Resgrid.Framework
@using Resgrid.Model
@using Resgrid.Model.Events
@using Resgrid.Web.Extensions
@using Resgrid.Web.Helpers
@model Resgrid.WebCore.Areas.User.Models.Links.LinksIndexView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Links.Links> localizer
@{
  ViewBag.Title = "Resgrid | " + localizer["PageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["DepartmentLinks"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
			</li>
			<li class="active">
				<strong>@localizer["DepartmentLinks"]</strong>
			</li>
		</ol>
	</div>
	@if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
	{
		<div class="col-sm-8">
			<div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
				<a title="Add a new department link" class="btn btn-success" asp-controller="Links" asp-action="New" asp-route-area="User">@localizer["NewDepartmentLinks"]</a>
			</div>
		</div>
	}
</div>

  <div class="row">
    @*@if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
	  {*@
    @*Html.Raw("<div class='col-xs-9'>");*@
    @*}
	  else
	  {
		Html.Raw("<div class='col-xs-12'>");
	  }*@
    <div class='col-xs-9'>
      <div class="wrapper wrapper-content">
        <div class="ibox float-e-margins">
          <div class="ibox-content">
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>@localizer["FromDepartment"]</th>
                    <th></th>
                    <th>@localizer["ToDepartment"]</th>
                    <th>@localizer["Enabled"]</th>
                    <th>@localizer["SharedData"]</th>
                    <th>@commonLocalizer["Actions"]</th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var l in Model.Links)
				  {
                    <tr>
                      <td>
                        <span>@l.Department.Name</span>
                      </td>
                      <td>
                        @if (l.DepartmentId != Model.DepartmentId && !String.IsNullOrWhiteSpace(l.DepartmentColor))
						{
                          <i class="fa fa-arrow-right" style="color: @l.DepartmentColor"></i>
						}
						else
						{
                          <i class="fa fa-arrow-right"></i>
						}
                      </td>
                      <td>
                        <span>@l.LinkedDepartment.Name</span>
                      </td>
                      <td>
                        @if (l.LinkEnabled)
						{
                          <span style="color: green;">@localizer["LinkEnabled"]</span>
						}
						else
						{
                          <span style="color: red;">@localizer["LinkDisabled"]</span>
						}
                      </td>
                      <td>
                        @{
						  var data = String.Empty;

						  if (l.DepartmentShareCalls)
						  {
							if (data.Length <= 0)
							{
							  data = localizer["Calls"];
							}
							else
							{
							  data = data + "," + localizer["Calls"];
							}
						  }

						  if (l.DepartmentSharePersonnel)
						  {
							if (data.Length <= 0)
							{
							  data = localizer["Personnel"];
							}
							else
							{
							  data = data + "," + localizer["Personnel"];
							}
						  }

						  if (l.DepartmentShareUnits)
						  {
							if (data.Length <= 0)
							{
							  data = localizer["Units"];
							}
							else
							{
							  data = data + "," + localizer["Units"];
							}
						  }

						  if (l.DepartmentShareOrders)
						  {
							if (data.Length <= 0)
							{
							  data = localizer["Orders"];
							}
							else
							{
							  data = data + "," + localizer["Orders"];
							}
						  }
                        }

                        @if (!String.IsNullOrWhiteSpace(data))
						{
                          <span>@data</span>
						}
						else
						{
                          <span>@localizer["NoDataShared"]</span>
						}
                      </td>
                      <td>
                        @if (l.DepartmentId != Model.DepartmentId && l.LinkEnabled == false && ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
						{
                          <a href="@Url.Action("Enable", "Links", new { area = "User", linkId = l.DepartmentLinkId })" class='btn btn-xs btn-success'>
                            @localizer["Enable"]
                          </a>
						}
						else if (l.DepartmentId != Model.DepartmentId && l.LinkEnabled && ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
						{
                          <a href="@Url.Action("DisableLink", "Links", new { area = "User", linkId = l.DepartmentLinkId })" class='btn btn-xs btn-warning'>
                            @localizer["Disable"]
                          </a>
						}

                        @if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
						{
                          <a href="@Url.Action("DeleteLink", "Links", new { area = "User", linkId = l.DepartmentLinkId })" class='btn btn-xs btn-danger' data-confirm="@localizer["DeleteLinkConfirm"]" rel="nofollow">
                            @localizer["Delete"]
                          </a>
						}


                        @if (l.DepartmentId != Model.DepartmentId && l.LinkEnabled)
						{
                          <a href="@Url.Action("View", "Links", new { area = "User", linkId = l.DepartmentLinkId })" class='btn btn-xs btn-primary'>
                            @localizer["ViewData"]
                          </a>
						}
                      </td>
                    </tr>
						  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    @if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin() && Model.CanCreateLinks)
	{
      <div class="col-xs-3">
        <div class="wrapper wrapper-content animated fadeInUp">
          <div class="ibox">
            <div class="ibox-content">
              <div id="gravatarSection" style="text-align: center; padding-top: 10px;">

                <span>@localizer["YourDepartmentLinkCode"]</span>
                <div style="color: #337ab7;">@Model.Code</div>
              </div>
            </div>
          </div>
        </div>
      </div>
	  }
  </div>

  @section Scripts
{

  }
