@using Resgrid.Model
@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Mapping.ViewTypeView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Mapping.Mapping> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["ViewTypePageTitle"];
	Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";
}

@section Styles
{
	<link rel="stylesheet" href="~/clib/mapMarkers/map-icons.css" />

	<style>
		.labels {
			color: red;
			background-color: white;
			font-family: "Lucida Grande", "Arial", sans-serif;
			font-size: 10px;
			font-weight: bold;
			text-align: center;
			width: 70px;
			border: 2px solid black;
			white-space: nowrap;
		}
	</style>
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["ViewTypeHeader"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
			</li>
			<li>
				<a asp-controller="Mapping" asp-action="Index" asp-route-area="User">@localizer["MappingHeader"]</a>
			</li>
			<li>
				<a asp-controller="Mapping" asp-action="POIs" asp-route-area="User">@localizer["POIsHeader"]</a>
			</li>
			<li class="active">
				<strong>@localizer["ViewTypeHeader"]</strong>
			</li>
		</ol>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
			<div class="tabs-container">
				<ul class="nav nav-tabs">
					<li class="active"><a data-toggle="tab" href="#tab-1">@localizer["TabMap"]</a></li>
					<li class=""><a data-toggle="tab" href="#tab-2">@localizer["TabInformation"]</a></li>
					<li class=""><a data-toggle="tab" href="#tab-3">@localizer["TabList"]</a></li>
				</ul>
				<div class="tab-content">
					<div id="tab-1" class="tab-pane active">
						<div class="panel-body">
							<div id="map" style="height: 650px; width: 100%;"></div>
						</div>
					</div>
					<div id="tab-2" class="tab-pane">
						<div class="panel-body">
							<div style="height: 650px;">
								<form class="form-horizontal">
									<div class="form-group">
										<label class="control-label required">
											@localizer["Name"]
										</label>
										<div class="controls">
											<div class="col-md-6">
												@Model.Type.Name
											</div>
										</div>
									</div>
									<div class="form-group">
										<label class="control-label required">
											@localizer["IsDestination"]
										</label>
										<div class="controls">
											<div class="col-md-6">
												@if (Model.Type.IsDestination)
												{
													<span>@localizer["True"]</span>
												}
												else
												{
													<span>@localizer["False"]</span>
												}
											</div>
										</div>
									</div>
									<div class="form-group">
										<label class="control-label required">
											@localizer["Color"]
										</label>
										<div class="controls">
											<div class="col-md-6">
												<span style="color: @Model.Type.Color;">@Model.Type.Color</span>
											</div>
										</div>
									</div>
								</form>
							</div>
						</div>
					</div>
					<div id="tab-3" class="tab-pane active">
						<div class="panel-body">
							<table id="poisGrid" class="table table-striped table-bordered table-hover" width="100%"></table>
						</div>
					</div>
				</div>
			</div>
		</div>
</div>

@section Scripts
{
    <script>
        var centerLat = '@Model.Latitude';
        var centerLon = '@Model.Longitude';
        var poiTypeId = '@Model.Type.PoiTypeId';
        var osmTileUrl = '@Resgrid.Config.MappingConfig.GetWebsiteOSMUrl()';
        var osmTileAttribution = '@Resgrid.Config.MappingConfig.LeafletAttribution';
    </script>
    <script src="~/js/app/internal/mapping/resgrid.mapping.viewType.js" type="text/javascript"></script>
}
