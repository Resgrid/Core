@using Resgrid.Model

@model Resgrid.WebCore.Areas.User.Models.Orders.OrderSetttingsView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Orders.Orders> localizer
@{
  ViewBag.Title = "Resgrid | " + localizer["OrderSettingsHeader"];
}

<div class="row wrapper border-bottom white-bg page-heading">
  <div class="col-sm-4">
    <h2>@localizer["OrderSettingsHeader"]</h2>
    <ol class="breadcrumb">
      <li>
        <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
      </li>
      <li class="active">
        <strong>@localizer["OrderSettingsHeader"]</strong>
      </li>
    </ol>
  </div>
</div>

<form role="form" class="form-horizontal" asp-controller="Orders" asp-action="Settings" asp-route-area="User" method="post">
  <div class="row">
    <div class="col-sm-12">
      <div class="wrapper wrapper-content">
        <div class="ibox float-e-margins">
          <div class="ibox-content">

            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["DoNotReceiveOrdersLabel"]</label>
              <div class="col-sm-9">
                <div class="checkbox checkbox-primary">
                  <input type="checkbox" asp-for="Settings.DoNotReceiveOrders">
                  <label></label>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["DefaultOrderVisibilityLabel"]</label>
              <div class="col-sm-9">
                @Html.DropDownListFor(m => m.Settings.Visibility, Model.OrderVisibilities, new { style = "width: 250px" })
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">
                @localizer["RangeForVisibilityLabel"]
              </label>
              <div class="col-sm-9">
                <input type="number" asp-for="Settings.Range" min="1" />
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["DefaultOrderManagerLabel"]</label>
              <div class="col-sm-3"><select asp-for="Settings.DefaultResourceOrderManagerUserId" asp-items="ViewBag.Users" style="padding-left: 0; width: 100%;"></select></div>
            </div>

            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["LimitOrderNotificationsLabel"]</label>
              <div class="col-sm-9">
                <div class="checkbox checkbox-primary">
                  <input type="checkbox" asp-for="Settings.LimitStaffingLevelToReceiveNotifications">
                  <label></label>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["AllowedNotificationStaffingLabel"]</label>
              <div class="col-sm-9">
                @Html.DropDownListFor(m => m.Settings.AllowedStaffingLevelToReceiveNotifications, Model.StaffingLevels, new { style = "width: 250px" })
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["AllowedDepartmentTypesLabel"]</label>
              <div class="col-sm-4">
                <select id="departmentTypes" name="departmentTypes"></select>
              </div>
            </div>
            <div class="form-group">
              <label class="col-sm-3 control-label">@localizer["AutomaticallyAcceptFillsLabel"]</label>
              <div class="col-sm-9">
                <div class="checkbox checkbox-primary">
                  <input type="checkbox" asp-for="Settings.AutomaticFillAcceptance">
                  <label></label>
                </div>
              </div>
            </div>
	          <div class="form-group">
		          <label class="col-sm-3 control-label">@localizer["NotifyRolesLabel"]</label>
		          <div class="col-sm-9">
			          <div class="checkbox checkbox-primary">
				          <input type="checkbox" asp-for="Settings.NotifyUsers">
				          <label></label>
			          </div>
		          </div>
	          </div>
		    <div class="form-group">
		      <label class="col-sm-3 control-label">@localizer["RolesToNotifyLabel"]</label>
		      <div class="col-sm-4">
		        <select id="notifyRoles" name="notifyRoles"></select>
		      </div>
		    </div>
            <div class="hr-line-dashed"></div>


            <div class="form-group">
              <div class="col-sm-4 col-sm-offset-2">
                <a class="btn btn-white" asp-controller="Orders" asp-action="Index" asp-route-area="User">@commonLocalizer["Cancel"]</a>
                <button class="btn btn-primary" type="submit">@localizer["SaveSettingsButton"]</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

@section Scripts
{
  <script src="~/js/app/internal/orders/resgrid.orders.settings.js" type="text/javascript"></script>
}
