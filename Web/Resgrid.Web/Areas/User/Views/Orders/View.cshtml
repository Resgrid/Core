@using Resgrid.Model
@model Resgrid.Web.Areas.User.Models.Orders.ViewOrderView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Orders.Orders> localizer
@{
  ViewBag.Title = "Resgrid | " + localizer["ViewOrderHeader"];
}

<div class="row wrapper border-bottom white-bg page-heading">
  <div class="col-sm-4">
	<h2>@localizer["ViewOrderHeader"]</h2>
	<ol class="breadcrumb">
	  <li>
		<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
	  </li>
	  <li>
		<a asp-controller="Orders" asp-action="Index" asp-route-area="User">@localizer["OrdersLabel"]</a>
	  </li>
	  <li class="active">
		<strong>@localizer["ViewOrderHeader"]</strong>
	  </li>
	</ol>
  </div>
</div>

<div class="row">
  <div class="col-lg-9">
	<div class="wrapper wrapper-content animated fadeInUp">
	  <div class="ibox">
		<div class="ibox-content">
		  <div class="row">
			<div class="col-lg-12">
			  <div class="m-b-md">
				@if (Model.Department.DepartmentId != Model.Order.DepartmentId && !Model.Order.IsFilled())
				{
				  <a asp-controller="Orders" asp-action="Fill" asp-route-area="User" asp-route-orderId="@Model.Order.ResourceOrderId" class="btn btn-success btn-xs pull-right">@localizer["RequestToFillButton"]</a>
				}
				<h2>@Model.Order.Title</h2>
			  </div>
			  <dl class="dl-horizontal">
				<dt>@localizer["StatusLabel"]</dt>
				<dd>
				  @if (Model.Order.CloseDate.HasValue)
				  {
					<span class="label label-info">@localizer["ClosedLabel"]</span>
				  }
				  else
				  {
					if (Model.Order.IsFilled())
					{
					  <span class="label label-success">@localizer["FilledLabel"]</span>
					}
					else
					{
					  <span class="label label-primary">@localizer["OpenLabel"]</span>
					}
				  }
				</dd>
			  </dl>
			</div>
		  </div>
		  <div class="row">
			<div class="col-lg-5">
			  <dl class="dl-horizontal">
				<dt>@localizer["CreatedByLabel"]</dt>
				<dd>@Model.Order.Department.Name</dd>
				<dt>@localizer["IncidentLabel"]</dt>
				<dd>@Model.Order.IncidentName</dd>
				<dt>@localizer["NumberIdLabel"]</dt>
				<dd>@Model.Order.IncidentNumber</dd>
				<dt>@localizer["FinanceCodeDtLabel"]</dt>
				<dd>@Model.Order.FinancialCode</dd>
			  </dl>
			</div>
			<div class="col-lg-7" id="cluster_info">
			  <dl class="dl-horizontal">
				<dt>@localizer["LastUpdatedLabel"]</dt>
				<dd>@Model.Order.OpenDate.TimeConverterToString(Model.Department)</dd>
				<dt>@localizer["CreatedDtLabel"]</dt>
				<dd>@Model.Order.OpenDate.TimeConverterToString(Model.Department)</dd>
				<dt>@localizer["ContactNameDtLabel"]</dt>
				<dd>@Model.Order.ContactName</dd>
				<dt>@localizer["ContactNumberDtLabel"]</dt>
				<dd>@Model.Order.ContactNumber</dd>
			  </dl>
			</div>
		  </div>
		  <div class="row">
			<div class="col-lg-12">
			  <dl class="dl-horizontal">
				<dt>@localizer["FillDtLabel"]</dt>
				<dd>
				  <div class="progress progress-striped active m-b-sm">
					<div style="width: @Model.Order.FilledPrecentage()%;" class="progress-bar"></div>
				  </div>
				  <small>@localizer["FillPercentageText"] <strong>@Model.Order.FilledPrecentage()%</strong> @localizer["FillPercentageText2"]</small>
				</dd>
			  </dl>
			</div>
		  </div>
		  <div class="row m-t-sm">
			<div class="col-lg-12">
			  <div class="panel blank-panel">
				<div class="panel-heading">
				  <div class="panel-options">
					<ul class="nav nav-tabs">
					  <li class="active"><a href="#tab-1" data-toggle="tab">@localizer["FillsTab"]</a></li>
					</ul>
				  </div>
				</div>
				<div class="panel-body">
				  <div class="tab-content">
					<div class="tab-pane active" id="tab-1">

					  @foreach (var item in Model.Order.Items)
					  {
						<div class="row">
						  <div class="col-md-4">
							<dl>
							  <dt>@localizer["ResourceDtLabel"]</dt>
							  <dd>@item.Resource</dd>
							</dl>
						  </div>
						  <div class="col-md-4">
							<dl>
							  <dt>@localizer["RequirementsDtLabel"]</dt>
							  <dd>@item.Requirements</dd>
							</dl>
						  </div>
						  <div class="col-md-2">
							<dl>
							  <dt>@localizer["MinDtLabel"]</dt>
							  <dd>@item.Min</dd>
							</dl>
						  </div>
						  <div class="col-md-2">
							<dl>
							  <dt>@localizer["MaxDtLabel"]</dt>
							  <dd>@item.Max</dd>
							</dl>
						  </div>
						</div>
						<table class="table table-striped">
						  <thead>
							<tr>
							  <th>@commonLocalizer["Status"]</th>
							  <th>@localizer["DepartmentColumn"]</th>
							  <th>@localizer["TimestampColumn"]</th>
							  <th>@localizer["ContactColumn"]</th>
							  <th>@localizer["NoteColumn"]</th>
							  <th>@localizer["UnitsColumn"]</th>
							  <th></th>
							</tr>
						  </thead>
						  <tbody>
							@foreach (var fill in item.Fills)
							{
							  <tr>
								<td>
								  @if (fill.Accepted)
								  {
									<span class="label label-success"><i class="fa fa-check"></i> @localizer["AcceptedLabel"]</span>
								  }
								  else if (Model.Order.CloseDate.HasValue)
								  {
									<span class="label label-danger">@localizer["NotAcceptedLabel"]</span>
								  }
								  else
								  {
									<span class="label label-primary">@localizer["PendingLabel"]</span>
								  }
								</td>
								<td>
								  @fill.Department.Name
								</td>
								<td>
								  @fill.FilledOn.TimeConverterToString(Model.Department)
								</td>
								<td>
								  <span>@fill.ContactName</span> <span>@fill.ContactNumber</span>
								</td>
								<td>
								  <p class="small">
									@fill.Note
								  </p>
								</td>
								<td>
								  @foreach (var unit in fill.Units)
								  {
									<span>@unit.Unit.Name</span><br />
								  }
								</td>
								  <td>
									  @if (!fill.Accepted && Model.Department.DepartmentId == Model.Order.DepartmentId)
									  {
										  <a asp-controller="Orders" asp-action="AcceptFill" asp-route-area="User" asp-route-fillId="@fill.ResourceOrderFillId" class="btn btn-white btn-xs">@localizer["AcceptButton"]</a>
									  }
								  </td>

							  </tr>
							}
						  </tbody>
						</table>
					  }
					</div>
				  </div>
				</div>
			  </div>
			</div>
		  </div>
		</div>
	  </div>
	</div>
  </div>
  <div class="col-lg-3">
	<div class="wrapper wrapper-content project-manager">
	  <h4>@localizer["OrderSummaryHeader"]</h4>
	  <p class="small">
		@Model.Order.Summary
	  </p>
	  <h4>@localizer["SpecialInstructionsHeader"]</h4>
	  <p class="small">
		@Model.Order.SpecialInstructions
	  </p>
	  <h4>@localizer["IncidentAddressHeader"]</h4>
	  <p class="small">
		@Model.Order.IncidentAddress
	  </p>
	  <h4>@localizer["MeetupHeader"]</h4>
	  <dl>
		<dt>   @localizer["MeetupLocationDtLabel"]</dt>
		<dd>@Model.Order.MeetupLocation</dd>
	  </dl>
	  <dl>
		<dt>   @localizer["MeetupDateDtLabel"]</dt>
		@if (Model.Order.MeetupDate.HasValue)
		{
		  <dd>@Model.Order.MeetupDate.Value.TimeConverterToString(Model.Department)</dd>
		}
		else
		{
		  <dd>@localizer["NotSuppliedLabel"]</dd>
		}
	  </dl>
	</div>
  </div>
</div>

@section Scripts
{

}
