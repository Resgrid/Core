@model Resgrid.Web.Areas.User.Models.Personnel.ViewPersonEventsView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Personnel.Person> localizer
@{
    ViewBag.Title = "Resgrid | " + @localizer["ViewPersonEventsHeader"];
}
@section Styles
    {

}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["EventsFor"] @Model.PersonName</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li>
                <a asp-controller="Personnel" asp-action="Index" asp-route-area="User">@commonLocalizer["PersonnelModule"]</a>
            </li>
            <li class="active">
                <strong>@localizer["EventsFor"] @Model.PersonName</strong>
            </li>
        </ol>
    </div>
    <div class="col-sm-8">
        <div class="btn-group top-page-buttons" style="float:right;padding-right:15px;">
            @if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
            {
                <span><a data-toggle="modal" data-target="#confirmClearAllPersonnelEventsModal" class="btn btn-xs btn-danger">@localizer["ClearAllStatuses"]</a> </span>
            }
        </div>
    </div>
</div>

@using (Html.BeginForm("GeneratePersonnelEventsReport", "Personnel", FormMethod.Post, new { area = "User", @class = "form-horizontal" }))
{
    <div class="row">
        <div class="col-xs-12">
            <div class="wrapper wrapper-content">
                <div class="ibox float-e-margins">
                    <div class="ibox-content">
                        <div class="row">
                            <div class="col-xs-7">
                                <table id="eventsGrid" class="table table-striped table-bordered table-hover" width="100%"></table>
                            </div>
                            <div class="col-xs-5 text-center">
                                <div id="eventsMap" name="eventsMap" style="position: relative; width: 100%; height: 500px;"></div>
                                <input class="btn btn-primary" id="submit_action" name="commit" type="submit" value="@localizer["GenerateReport"]" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-12">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" tabindex="-1" role="dialog" aria-labelledby="confirmClearAllPersonnelEventsLabel" aria-hidden="true" id="confirmClearAllPersonnelEventsModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="confirmClearAllPersonnelEventsLabel">@localizer["ClearAllStatuses"]</h4>
            </div>
            @using (Html.BeginForm("ClearAllPersonnelEvents", "Personnel", FormMethod.Post, new { area = "User", id = "clear_all" }))
            {
                <div class="modal-body">
                    <span class="alert alert-error">
                        @Html.ValidationSummary(false)
                        @Html.HiddenFor(m => m.UserId)
                        @Html.AntiForgeryToken()
                    </span>
                    <div class="form-group">
                        <label class="control-label">
                            @localizer["AreYouSurePersonnel"]
                        </label>
                        <div class="controls">
                            @Html.CheckBoxFor(m => m.ConfirmClearAll) @localizer["YesImSure"]
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <a href="#" class="btn" data-dismiss="modal">@commonLocalizer["Cancel"]</a>
                    <input class="btn btn-primary" id="clear_all_submit" name="commit" type="submit"
                           value="@localizer["DeleteAll"]" />
                </div>
            }
        </div>
    </div>
</div>

@section Scripts
    {
    <script>
        var personnelUserId = '@Model.UserId';
        var osmKey = '@Model.OSMKey';
        var osmTileUrl = '@Resgrid.Config.MappingConfig.GetWebsiteOSMUrl()';
        var centerLat = '@Model.CenterLat';
        var centerLon = '@Model.CenterLon';
    </script>
    <script src="@Url.Content("~/js/app/internal/personnel/resgrid.personnel.viewevents.js")"></script>
}
