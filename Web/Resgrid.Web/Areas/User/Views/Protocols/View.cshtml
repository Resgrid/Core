@using Resgrid.Model
@using Resgrid.Framework
@model Resgrid.WebCore.Areas.User.Models.Protocols.ViewProtocolModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Protocols.Protocols> localizer
@{
  ViewBag.Title = "Resgrid | " + localizer["ViewProtocolHeader"];
}

<div class="row wrapper border-bottom white-bg page-heading">
  <div class="col-sm-4">
    <h2>@localizer["ViewProtocolHeader"]</h2>
    <ol class="breadcrumb">
      <li>
        <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
      </li>
      <li>
        <a asp-controller="Protocols" asp-action="Index" asp-route-area="User">@localizer["ProtocolsLabel"]</a>
      </li>
      <li class="active">
        <strong>@localizer["ViewProtocolHeader"]</strong>
      </li>
    </ol>
  </div>
</div>

<div class="row">
  <div class="col-lg-12">
    <div class="wrapper wrapper-content animated fadeInUp">
      <div class="ibox">
        <div class="ibox-content">
          <div class="row">
            <div class="col-lg-12">
              <div class="m-b-md">
                <h2>@Model.Protocol.Name</h2>
              </div>
              <dl class="dl-horizontal" style="margin-bottom: 0px;">
                <dt>@localizer["StatusLabel"]</dt>
                <dd>
                  @if (Model.Protocol.IsDisabled == false)
				  {
                    <span style="display: block; color: green;">@localizer["ActiveLabel"]</span>
				  }
				  else
				  {
                    <span style="display: block; color: black;">@localizer["DisabledLabel"]</span>
				  }
                </dd>
              </dl>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-5">
              <dl class="dl-horizontal">
                <dt>@localizer["CodeLabel"]</dt>
                <dd>@Model.Protocol.Code</dd>
                <dt>@localizer["TypeLabel"]</dt>
                <dd>
                  <span style="display: block;">@localizer["DispatchProtocolLabel"]</span>
                </dd>
              </dl>
            </div>
            <div class="col-lg-7" id="cluster_info">
              <dl class="dl-horizontal">
                <dt>@localizer["CreatedByLabel"]</dt>
                <dd>@(await UserHelper.GetFullNameForUser(Model.Protocol.CreatedByUserId))</dd>
                <dt>@localizer["CreatedOnLabel"]</dt>
                <dd>@Model.Protocol.CreatedOn.TimeConverterToString(Model.Department)</dd>
                <dt>@localizer["WeightLabel"]</dt>
                <dd>@Model.Protocol.MinimumWeight</dd>
              </dl>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12">
              <dl class="dl-horizontal">
                <dt>@localizer["DescriptionDtLabel"]</dt>
                <dd>
                  @Html.Raw(Model.Protocol.Description)
                </dd>
              </dl>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12">
              <dl class="dl-horizontal">
                <dt>@localizer["ProtocolTextDtLabel"]</dt>
                <dd>
                  @Html.Raw(Model.Protocol.ProtocolText)
                </dd>
              </dl>
            </div>
          </div>
          <div class="row m-t-sm">
            <div class="col-lg-12">
              <div class="panel blank-panel">
                <div class="panel-heading">
                  <div class="panel-options">
                    <ul class="nav nav-tabs">
                      <li class="active"><a href="#tab-1" data-toggle="tab" aria-expanded="true">@localizer["TriggersTab"]</a></li>
                      <li class=""><a href="#tab-2" data-toggle="tab" aria-expanded="false">@localizer["AttachmentsTab"]</a></li>
                      <li class=""><a href="#tab-3" data-toggle="tab" aria-expanded="false">@localizer["QuestionsTab"]</a></li>
                    </ul>
                  </div>
                </div>
                <div class="panel-body">
                  <div class="tab-content">
                    <div class="tab-pane active" id="tab-1">
                      <table class="table table-striped">
                        <thead>
                          <tr>
                            <th>@localizer["TriggerTypeColumn"]</th>
                            <th>@localizer["TriggerStartsOnColumn"]</th>
                            <th>@localizer["TriggerEndsOnColumn"]</th>
                            <th>@localizer["TriggerPriorityColumn"]</th>
                            <th>@localizer["TriggerCallTypeColumn"]</th>
                          </tr>
                        </thead>
                        <tbody>
                          @foreach (var t in Model.Protocol.Triggers)
						  {
                            <tr>
                              <td>
                                @if (t.Type == 0)
								{
                                  <span>@localizer["CallPriorityTrigger"]</span>
								}
								else if (t.Type == 1)
								{
                                  <span>@localizer["CallTypeTrigger"]</span>
								}
								else if (t.Type == 2)
								{
                                  <span>@localizer["CallPriorityAndTypeTrigger"]</span>
								}
                              </td>
                              <td>
                                @if (!t.StartsOn.HasValue)
								{
                                  <span>@localizer["NoStartDate"]</span>
								}
								else
								{
                                  <span>@t.StartsOn.Value.TimeConverterToString(Model.Department)</span>
								}
                              </td>
                              <td>
                                @if (!t.EndsOn.HasValue)
								{
                                  <span>@localizer["NoEndDate"]</span>
								}
								else
								{
                                  <span>@t.EndsOn.Value.TimeConverterToString(Model.Department)</span>
								}
                              </td>
                              <td>
                                @if (t.Priority.HasValue && (t.Type == 2 || t.Type == 0))
								{
                                <span>@(await CallPriorityHelper.CallPriorityToString(Model.Department.DepartmentId, t.Priority.Value))</span>
								}
								else
								{
                                  <span>@localizer["NotApplicableLabel"]</span>
								}
                              </td>
                              <td>
                                @if (t.Type == 2 || t.Type == 1)
								{
                                  <span>@t.CallType</span>
								}
								else
								{
                                  <span>@localizer["NotApplicableLabel"]</span>
								}
                              </td>
                            </tr>
						  }
                        </tbody>
                      </table>
                    </div>
                    <div class="tab-pane" id="tab-2">
                      <table class="table table-striped">
                        <thead>
                          <tr>
                            <th>@localizer["FileNameColumn"]</th>
                            <th>@localizer["FileTypeColumn"]</th>
                            <th>@localizer["SizeColumn"]</th>
                          </tr>
                        </thead>
                        <tbody>
                          @foreach (var a in Model.Protocol.Attachments)
                          {
                            <tr>
                              <td>
                                <span>@a.FileName</span>
                              </td>
                              <td>
                                <span>@a.FileType</span>
                              </td>
                              <td>
                                @if (a.Data != null && a.Data.Length > 0)
                                {
                                  <span>@((long)a.Data.Length).GetSizeInMemory()</span>
                                }
                                else
                                {
                                  <span>0</span>
                                }
                              </td>
                            </tr>
                          }
                        </tbody>
                      </table>
                    </div>
                    <div class="tab-pane" id="tab-3">
                      <table class="table table-striped">
                        <thead>
                          <tr>
                            <th>@localizer["QuestionColumn"]</th>
                            <th>@localizer["AnswersColumn"]</th>
                          </tr>
                        </thead>
                        <tbody>
                          @foreach (var q in Model.Protocol.Questions)
                          {
                            <tr>
                              <td style="width:450px;">
                                <span>@q.Question</span>
                              </td>
                              <td>
                                <table class="table table-striped">
                                  <thead>
                                    <tr>
                                      <th>@localizer["WeightColumn"]</th>
                                      <th>@localizer["AnswerColumn"]</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    @foreach (var a in q.Answers)
                                    {
                                      <tr>
                                        <td>
                                          <span>@a.Weight</span>
                                        </td>
                                        <td>
                                          <span>@a.Answer</span>
                                        </td>
                                      </tr>
                                    }
                                  </tbody>
                                </table>
                              </td>
                            </tr>
                          }
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts
{

}
