                                    <a href="@Url.Action("CallSummaryReportParams", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@Url.Action("PersonnelStaffingHistoryReportParams", "Reports", new { Area = "User" })">@localizer["PersonnelStaffingHistoryReportName"]</a>
                                </td>
                                <td>
                                    @localizer["PersonnelStaffingHistoryReportDescription"]
                                </td>
                                <td>
                                    <a href="@Url.Action("PersonnelStaffingHistoryReportParams", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@Url.Action("UnitStateHistoryReportParams", "Reports", new { Area = "User" })">@localizer["UnitStateHistoryReportName"]</a>
                                </td>
                                <td>
                                    @localizer["UnitStateHistoryReportDescription"]
                                </td>
                                <td>
                                    <a href="@Url.Action("UnitStateHistoryReportParams", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@Url.Action("ActiveCallsResourcesReport", "Reports", new { Area = "User" })">@localizer["ActiveCallsResourcesReportName"]</a>
                                </td>
                                <td>
                                    @localizer["ActiveCallsResourcesReportDescription"]
                                </td>
                                <td>
                                    <a href="@Url.Action("ActiveCallsResourcesReport", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            @if (ClaimsAuthorizationHelper.IsUserDepartmentAdmin())
                            {
                                <tr>
                                    <td>
                                        <a href="@Url.Action("FlaggedCallNotesReportParams", "Reports", new { Area = "User" })">@flaggedReportLocalizer["ReportTitle"]</a>
                                    </td>
                                    <td>
                                        @flaggedReportLocalizer["ReportIndexDescription"]
