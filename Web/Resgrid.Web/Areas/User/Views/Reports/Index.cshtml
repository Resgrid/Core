                                    <a href="@Url.Action("DepartmentActivityReport", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@Url.Action("PersonnelHoursReportParams", "Reports", new { Area = "User" })">@localizer["PersonnelHoursReportName"]</a>
                                </td>
                                <td>
                                    @localizer["PersonnelHoursReportDescription"]
                                </td>
                                <td>
                                    <a href="@Url.Action("PersonnelHoursReportParams", "Reports", new { Area = "User" })" class=" btn btn-primary btn-sm"><i class="icon-eye-open"></i> @localizer["ViewReport"]</a>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="@Url.Action("CallSummaryReportParams", "Reports", new { Area = "User" })">@localizer["CallSummaryReportName"]</a>
                                </td>
                                <td>
                                    @localizer["CallSummaryReportDescription"]
                                </td>
