@using Resgrid.Model.Helpers
@using Resgrid.Web
@using Resgrid.Web.Helpers
@using Microsoft.Extensions.Localization
@model Resgrid.Web.Areas.User.Models.Reports.Personnel.PersonnelHoursView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Reports.Reports> localizer
@{
	Layout = null;
}

<!DOCTYPE html>

<html lang="en">
<head>
	<title>@localizer["PersonnelHoursReportTitle"]</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="description" content="@localizer["PersonnelHoursReportTitle"]">
	<meta name="author" content="Resgrid">

	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"
				crossorigin="anonymous"
				asp-fallback-href="~/lib/bootstrap/dist/css/bootstrap.min.css"
				asp-fallback-test-class="hidden"
				asp-fallback-test-property="visibility" asp-fallback-test-value="hidden" />



	<style>
		.table th, .table td {
			padding: 8px !important;
			line-height: 20px !important;
			text-align: left !important;
			vertical-align: top !important;
		}
	</style>

	<!--[if lt IE 9]>
		<script src="https://html5shim.googlecode.com/svn/trunk/html5.js"></script>
	<![endif]-->

	<link rel="shortcut icon" href="@Url.Content("~/favicon.ico")" />
	<link rel="apple-touch-icon" href="@Url.Content("~/apple-touch-icon-iphone.png")" />
	<link rel="apple-touch-icon" sizes="72x72" href="@Url.Content("~/apple-touch-icon-ipad.png")" />
	<link rel="apple-touch-icon" sizes="114x114" href="@Url.Content("~/apple-touch-icon-iphone4.png")" />
	<link rel="apple-touch-icon" sizes="144x144" href="@Url.Content("~/apple-touch-icon-ipad3.png")" />
</head>
<body>
	<div class="content">
		<div class="row">
			<div class="col-md-4 col-md-offset-1">
				<img src="@Url.Content("~/images/Resgrid_JustText_small.png")" title="Resgrid Logo" style="margin-top: 10px; margin-bottom: 5px;">
			</div>
			<div class="col-md-6" style="text-align: right;">
				<h3 style="margin-top: 10px;">@localizer["PersonnelHoursReportTitle"]</h3>
				<span>@Model.Start.FormatForDepartment(Model.Department)</span><span>-</span><span>@Model.End.FormatForDepartment(Model.Department)</span>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<h4>@localizer["CallHours"]</h4>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<table class="table table-condensed">
					<thead>
					<tr>
						<th>@localizer["IdHeader"]</th>
						<th>@localizer["NameHeader"]</th>
						<th>@localizer["GroupHeader"]</th>
						<th>@localizer["CountHeader"]</th>
						<th>@localizer["HoursHeader"]</th>
					</tr>
					</thead>
					<tbody>
					@foreach (var response in Model.CallsHours)
					{
						<tr>
							<td style="padding-left: 10px;">@response.ID</td>
							<td>@response.Name</td>
							<td>@response.Group</td>
							<td>@response.TotalCalls</td>
							<td>@response.GetTimeSpan().ToString(@"d\d\:h\h\:m\m\:s\s", System.Globalization.CultureInfo.InvariantCulture)</td>
						</tr>
					}
					</tbody>
				</table>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<h4>@localizer["WorkHours"]</h4>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<table class="table table-condensed">
					<thead>
						<tr>
							<th>@localizer["IdHeader"]</th>
							<th>@localizer["NameHeader"]</th>
							<th>@localizer["GroupHeader"]</th>
							<th>@localizer["CountHeader"]</th>
							<th>@localizer["HoursHeader"]</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var training in Model.WorkHours)
						{
							<tr>
								<td style="padding-left: 10px;">@training.ID</td>
								<td>@training.Name</td>
								<td>@training.Group</td>
								<td>@training.TotalWorkLogs</td>
								<td>@training.GetTimeSpan().ToString(@"d\d\:h\h\:m\m\:s\s", System.Globalization.CultureInfo.InvariantCulture)</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<h4>@localizer["TrainingHours"]</h4>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<table class="table table-condensed">
					<thead>
						<tr>
							<th>@localizer["IdHeader"]</th>
							<th>@localizer["NameHeader"]</th>
							<th>@localizer["GroupHeader"]</th>
							<th>@localizer["CountHeader"]</th>
							<th>@localizer["HoursHeader"]</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var training in Model.TrainingHours)
						{
							<tr>
								<td style="padding-left: 10px;">@training.ID</td>
								<td>@training.Name</td>
								<td>@training.Group</td>
								<td>@training.TotalTrainings</td>
								<td>@training.GetTimeSpan().ToString(@"d\d\:h\h\:m\m\:s\s", System.Globalization.CultureInfo.InvariantCulture)</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1" style="text-align: right;">
				@Model.RunOn.FormatForDepartment(Model.Department)
			</div>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<!-- Latest compiled and minified JavaScript -->
	<script src="~/lib/bootstrap/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>


</body>
</html>
