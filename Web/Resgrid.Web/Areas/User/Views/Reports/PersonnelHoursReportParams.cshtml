
@using Resgrid.Framework
@using Resgrid.Model
@using Resgrid.Web.Helpers
@using Microsoft.Extensions.Localization
@model Resgrid.Web.Areas.User.Models.Reports.Params.PersonnelHoursReportParams
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Reports.Reports> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["PersonnelHoursReportName"];
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["PersonnelHoursReportName"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["Home"]</a>
			</li>
			<li>
				<a asp-controller="Reports" asp-action="Index" asp-route-area="User">@localizer["Reports"]</a>
			</li>
			<li class="active">
				<strong>@localizer["PersonnelHoursReportName"]</strong>
			</li>
		</ol>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
		<div class="wrapper wrapper-content">
			<div class="ibox float-e-margins">
				<div class="ibox-content">
					<form class="form-horizontal" role="form" asp-controller="Reports" asp-action="PersonnelHoursReportParams" asp-route-area="User" method="post">

						<div class="row">
							<div class="col-md-8 col-md-offset-1">
								@Html.AntiForgeryToken()
								<div asp-validation-summary="All" class="text-danger"></div>
							</div>
						</div>

						<div class="form-group">
							<label class="col-sm-2 control-label required">
								@localizer["UsersLabel"]
							</label>
							<div class="col-sm-10">
								@Html.DropDownListFor(m => m.UserId, Model.Users, new { @style = "width: 450px;" })
							</div>
						</div>
						<div class="form-group">
							<label class="col-sm-2 control-label required">
								@localizer["ReportStartTime"]
							</label>
							<div class="col-sm-10">
								@Html.TextBoxFor(m => m.Start, new { style = "width:250px;", onkeydown = "javascript:return false;" })
							</div>
						</div>
						<div class="form-group">
							<label class="col-sm-2 control-label required">
								@localizer["ReportEndTime"]
							</label>
							<div class="col-sm-10">
								@Html.TextBoxFor(m => m.End, new { style = "width:250px;", onkeydown = "javascript:return false;" })
							</div>
						</div>

						<div class="form-group">
							<div class="col-sm-4 col-sm-offset-2">
								<a class="btn btn-white" asp-controller="Reports" asp-action="Index" asp-route-area="User">@commonLocalizer["Cancel"]</a>
								<button class="btn btn-primary" type="submit">@localizer["RunReport"]</button>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>


@section Scripts
{
<script>
		$(document).ready(function () {
			$("#Start").datetimepicker({ step: 30 });
			$("#End").datetimepicker({ step: 30 });
		});
</script>
}
