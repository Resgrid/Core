@using Resgrid.Model.Helpers
@using Resgrid.Web.Helpers
@using Microsoft.Extensions.Localization
@model Resgrid.Web.Areas.User.Models.Reports.Personnel.PersonnelReportView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Reports.Reports> localizer
@{
	Layout = null;
}

<!DOCTYPE html>

<html lang="en">
<head>
	<title>@localizer["PersonnelReportTitle"]</title>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="description" content="@localizer["PersonnelReportTitle"]">
	<meta name="author" content="Resgrid">

	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"
				crossorigin="anonymous"
				asp-fallback-href="~/lib/bootstrap/dist/css/bootstrap.min.css"
				asp-fallback-test-class="hidden"
				asp-fallback-test-property="visibility" asp-fallback-test-value="hidden" />

	<style>
		.table th, .table td {
			padding: 8px !important;
			line-height: 20px !important;
			text-align: left !important;
			vertical-align: top !important;
		}
	</style>

	<!--[if lt IE 9]>
		<script src="http://html5shim.googlecode.com/svn/trunk/html5.js"></script>
	<![endif]-->

	<link rel="shortcut icon" href="@Url.Content("~/favicon.ico")" />
	<link rel="apple-touch-icon" href="@Url.Content("~/apple-touch-icon-iphone.png")" />
	<link rel="apple-touch-icon" sizes="72x72" href="@Url.Content("~/apple-touch-icon-ipad.png")" />
	<link rel="apple-touch-icon" sizes="114x114" href="@Url.Content("~/apple-touch-icon-iphone4.png")" />
	<link rel="apple-touch-icon" sizes="144x144" href="@Url.Content("~/apple-touch-icon-ipad3.png")" />
</head>
<body>
	<div class="content">
		<div class="row">
			<div class="col-md-5 col-md-offset-1">
				<img src="@Url.Content("~/images/Resgrid_JustText_small.png")" title="Resgrid Logo" style="margin-top: 10px; margin-bottom: 5px;">
			</div>
			<div class="col-md-5" style="text-align: right;">
				<h3 style="margin-top: 10px;">@localizer["PersonnelReportTitle"]</h3>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1">
				<table class="table table-bordered">
					<thead>
						<tr>
							<th>@localizer["IdHeader"]</th>
							<th>@localizer["NameHeader"]</th>
							<th>@localizer["UsernameHeader"]</th>
							<th>@localizer["TypeHeader"]</th>
							<th>@localizer["GroupHeader"]</th>
							<th>@localizer["RolesHeader"]</th>
							<th>@localizer["EmailHeader"]</th>
							<th>@localizer["MobileNumberHeader"]</th>
							<th>@localizer["MailingAddressHeader"]</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var row in Model.Rows)
						{
							<tr>
								<td>@row.ID</td>
								<td>@row.Name</td>
								<td>@row.Username</td>
								<td>@row.DepartmentRole</td>
								<td>@row.Group</td>
								<td>@row.Roles</td>
								<td>@row.Email</td>
								<td>@row.MobilePhoneNumber</td>
								<td>@Html.Raw(row.MailingAddress)</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
		<div class="row">
			<div class="col-md-10 col-md-offset-1" style="text-align: right;">
				@Model.RunOn.FormatForDepartment(Model.Department)
			</div>
		</div>
	</div>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>

	<!-- Latest compiled and minified JavaScript -->
	<script src="~/lib/bootstrap/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
</body>
</html>
