@model Resgrid.Web.Areas.User.Models.Routes.ActiveRoutesView
@{
    ViewBag.Title = "Resgrid | Active Routes";
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-12">
        <h2>Active Routes</h2>
        <ol class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">Home</a></li>
            <li><a asp-controller="Routes" asp-action="Index" asp-route-area="User">Routes</a></li>
            <li class="active"><strong>Active</strong></li>
        </ol>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        @if (Model.Instances.Count == 0)
        {
            <div class="col-lg-12">
                <div class="ibox float-e-margins">
                    <div class="ibox-content text-center">
                        <h3>No Active Routes</h3>
                        <p class="text-muted">There are no route instances currently in progress.</p>
                    </div>
                </div>
            </div>
        }
        @foreach (var instance in Model.Instances)
        {
            var plan = Model.Plans.FirstOrDefault(p => p.RoutePlanId == instance.RoutePlanId);
            var pct = instance.StopsTotal > 0 ? (instance.StopsCompleted * 100 / instance.StopsTotal) : 0;
            <div class="col-lg-4 col-md-6">
                <div class="ibox float-e-margins">
                    <div class="ibox-title">
                        <h5>@(plan?.Name ?? "Unknown Route")</h5>
                        <span class="label label-primary pull-right">@((Resgrid.Model.RouteInstanceStatus)instance.Status)</span>
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            <div class="col-xs-6">
                                <small class="stats-label">Unit</small>
                                <h4>@instance.UnitId</h4>
                            </div>
                            <div class="col-xs-6">
                                <small class="stats-label">Stops</small>
                                <h4>@instance.StopsCompleted / @instance.StopsTotal</h4>
                            </div>
                        </div>
                        <div class="progress progress-mini">
                            <div class="progress-bar" style="width: @(pct)%"></div>
                        </div>
                        <div class="m-t-sm small">
                            Started: @(instance.ActualStartOn?.ToString("HH:mm") ?? "-")
                        </div>
                        <a class="btn btn-xs btn-primary m-t-sm" asp-controller="Routes" asp-action="InstanceDetail" asp-route-instanceId="@instance.RouteInstanceId" asp-route-area="User">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/app/internal/routes/resgrid.routes.activeroutes.js"></script>
}
