@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Security.SsoIndexView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Security.Security> localizer
@{
    ViewBag.Title = "Resgrid | " + localizer["SsoPageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-6">
        <h2><i class="fa fa-shield"></i> @localizer["SsoPageHeader"]</h2>
        <ol class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">Home</a></li>
            <li><a asp-controller="Security" asp-action="Index" asp-route-area="User">Security</a></li>
            <li class="active"><strong>@localizer["SsoBreadcrumb"]</strong></li>
        </ol>
    </div>
    <div class="col-sm-6">
        <div class="title-action">
            <a asp-action="SecurityPolicy" class="btn btn-default">
                <i class="fa fa-lock"></i> @localizer["SsoSecurityPolicyButton"]
            </a>
            @if (!Model.HasOidcConfig)
            {
                <a asp-action="SsoNew" asp-route-providerType="oidc" class="btn btn-primary">
                    <i class="fa fa-plus"></i> @localizer["SsoAddOidcButton"]
                </a>
            }
            @if (!Model.HasSamlConfig)
            {
                <a asp-action="SsoNew" asp-route-providerType="saml2" class="btn btn-primary">
                    <i class="fa fa-plus"></i> @localizer["SsoAddSamlButton"]
                </a>
            }
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">

    @if (TempData["SsoSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible">
            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            <i class="fa fa-check-circle"></i> @TempData["SsoSuccess"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.NewScimBearerToken))
    {
        <!-- ── One-time SCIM token alert ──────────────────────────────────── -->
        <div class="row">
            <div class="col-lg-12">
                <div class="alert alert-warning" id="newTokenAlert">
                    <h4><i class="fa fa-exclamation-triangle"></i> @localizer["ScimSetupTokenWarningTitle"]</h4>
                    <p>@localizer["ScimSetupTokenWarningBody"]</p>
                    <div class="input-group m-t-sm">
                        <input type="text" class="form-control font-monospace" id="newTokenField"
                               value="@Model.NewScimBearerToken" readonly />
                        <span class="input-group-btn">
                            <button class="btn btn-warning" type="button" onclick="copyToClipboard('newTokenField')">
                                <i class="fa fa-copy"></i> @localizer["SsoScimTokenCopyButton"]
                            </button>
                        </span>
                    </div>
                    <p class="m-t-sm text-muted small">
                        <i class="fa fa-lock"></i> @localizer["SsoScimTokenEncryptedNote"]
                    </p>
                </div>
            </div>
        </div>
    }

    <!-- ── Overview panel ─────────────────────────────────────────── -->
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5><i class="fa fa-info-circle"></i> @localizer["SsoWhatIsSsoHeader"]</h5>
                    <div class="ibox-tools">
                        <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                    </div>
                </div>
                <div class="ibox-content">
                    <div class="row">
                        <div class="col-md-4">
                            <h4><i class="fa fa-sign-in text-primary"></i> @localizer["SsoSingleSignOnHeader"]</h4>
                            <p>@localizer["SsoSingleSignOnDescription"]</p>
                            <ul>
                                <li><strong>OIDC</strong> — @localizer["SsoOidcDescription"]</li>
                                <li><strong>SAML 2.0</strong> — @localizer["SsoSamlDescription"]</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <h4><i class="fa fa-users text-success"></i> @localizer["SsoScimHeader"]</h4>
                            <p>@localizer["SsoScimDescription"]</p>
                            <ul>
                                <li>@localizer["SsoScimAutoCreate"]</li>
                                <li>@localizer["SsoScimAutoDisable"]</li>
                                <li>@localizer["SsoScimSyncNames"]</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <h4><i class="fa fa-shield text-warning"></i> @localizer["SsoSecurityPolicyHeader"]</h4>
                            <p>@localizer["SsoSecurityPolicyDescription"]</p>
                            <ul>
                                <li>@localizer["SsoSecurityPolicyMandateMfa"]</li>
                                <li>@localizer["SsoSecurityPolicyRestrictLogin"]</li>
                                <li>@localizer["SsoSecurityPolicyIpRestrict"]</li>
                                <li>@localizer["SsoSecurityPolicyPasswordRules"]</li>
                                <li>@localizer["SsoSecurityPolicyDataClassification"]</li>
                            </ul>
                        </div>
                    </div>
                    <!-- Discovery URL callout -->
                    <div class="alert alert-info m-t-md">
                        <strong><i class="fa fa-link"></i> @localizer["SsoDiscoveryUrlCalloutTitle"]</strong>
                        <p class="m-b-none m-t-xs">@localizer["SsoDiscoveryUrlCalloutDescription"]</p>
                        <div class="input-group m-t-xs">
                            <input type="text" class="form-control input-sm font-monospace" id="discoveryUrlField"
                                   value="@Model.SsoDiscoveryUrl" readonly />
                            <span class="input-group-btn">
                                <button class="btn btn-sm btn-default" onclick="copyToClipboard('discoveryUrlField')" type="button">
                                    <i class="fa fa-copy"></i> @localizer["SsoCopyButton"]
                                </button>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── SCIM API Reference panel ──────────────────────────────────────── -->
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5><i class="fa fa-plug"></i> @localizer["SsoScimApiReferenceHeader"]</h5>
                    <div class="ibox-tools"><a class="collapse-link"><i class="fa fa-chevron-up"></i></a></div>
                </div>
                <div class="ibox-content">
                    <p class="text-muted">@localizer["SsoScimApiReferenceDescription"]</p>

                    <!-- Connection details -->
                    <div class="row m-b-md">
                        <div class="col-md-6">
                            <table class="table table-bordered table-condensed">
                                <tr>
                                    <th style="width:42%">@localizer["SsoScimBaseUrlLabel"]</th>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control font-monospace" id="scimBaseUrlRef"
                                                   value="@Model.ScimBaseUrl" readonly />
                                            <span class="input-group-btn">
                                                <button type="button" class="btn btn-default btn-sm"
                                                        onclick="copyToClipboard('scimBaseUrlRef')"><i class="fa fa-copy"></i></button>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <th>@localizer["SsoScimAuthHeaderLabel"]</th>
                                    <td><code>Authorization: Bearer &lt;token&gt;</code></td>
                                </tr>
                                <tr>
                                    <th>@localizer["SsoScimDeptHeaderLabel"]</th>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control font-monospace" id="scimDeptHeaderRef"
                                                   value="@Resgrid.Config.SsoConfig.ScimDepartmentIdHeaderName: @Model.DepartmentId" readonly />
                                            <span class="input-group-btn">
                                                <button type="button" class="btn btn-default btn-sm"
                                                        onclick="copyToClipboard('scimDeptHeaderRef')"><i class="fa fa-copy"></i></button>
                                            </span>
                                        </div>
                                        <small class="text-muted">@localizer["SsoScimDeptHeaderNote"]</small>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-bordered table-condensed small">
                                <thead>
                                    <tr>
                                        <th>@localizer["SsoScimMethodColumn"]</th>
                                        <th>@localizer["SsoScimEndpointColumn"]</th>
                                        <th>@localizer["SsoScimDescriptionColumn"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td><span class="badge badge-primary">GET</span></td><td><code>/Users</code></td><td>@localizer["SsoScimListUsersDesc"]</td></tr>
                                    <tr><td><span class="badge badge-primary">GET</span></td><td><code>/Users/{id}</code></td><td>@localizer["SsoScimGetUserDesc"]</td></tr>
                                    <tr><td><span class="badge badge-success">POST</span></td><td><code>/Users</code></td><td>@localizer["SsoScimCreateUserDesc"]</td></tr>
                                    <tr><td><span class="badge badge-warning">PUT</span></td><td><code>/Users/{id}</code></td><td>@localizer["SsoScimUpdateUserDesc"]</td></tr>
                                    <tr><td><span class="badge badge-warning">PATCH</span></td><td><code>/Users/{id}</code></td><td>@localizer["SsoScimPatchUserDesc"]</td></tr>
                                    <tr><td><span class="badge badge-danger">DELETE</span></td><td><code>/Users/{id}</code></td><td>@localizer["SsoScimDeleteUserDesc"]</td></tr>
                                    <tr><td><span class="badge badge-primary">GET</span></td><td><code>/Groups</code></td><td>@localizer["SsoScimListGroupsDesc"]</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Example requests -->
                    <h5 class="m-t-none"><i class="fa fa-code"></i> @localizer["SsoScimExampleRequestsHeader"]</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>@localizer["SsoScimExampleListUsers"]</strong></p>
                            <pre class="pre-scrollable small">GET @(Model.ScimBaseUrl)/Users?startIndex=1&amp;count=10
Authorization: Bearer &lt;your-scim-token&gt;
@(Resgrid.Config.SsoConfig.ScimDepartmentIdHeaderName): @Model.DepartmentId</pre>
                        </div>
                        <div class="col-md-6">
                            <p><strong>@localizer["SsoScimExampleProvisionUser"]</strong></p>
                            <pre class="pre-scrollable small">POST @(Model.ScimBaseUrl)/Users
Authorization: Bearer &lt;your-scim-token&gt;
@(Resgrid.Config.SsoConfig.ScimDepartmentIdHeaderName): @Model.DepartmentId
Content-Type: application/scim+json

{
  "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
  "userName": "jane.doe@example.com",
  "name": { "givenName": "Jane", "familyName": "Doe" },
  "emails": [{ "value": "jane.doe@example.com", "primary": true }],
  "active": true
}</pre>
                        </div>
                    </div>
                    <div class="row m-t-sm">
                        <div class="col-md-6">
                            <p><strong>@localizer["SsoScimExampleDeactivateUser"]</strong></p>
                            <pre class="pre-scrollable small">PATCH @(Model.ScimBaseUrl)/Users/{scim-user-id}
Authorization: Bearer &lt;your-scim-token&gt;
@(Resgrid.Config.SsoConfig.ScimDepartmentIdHeaderName): @Model.DepartmentId
Content-Type: application/scim+json

{
  "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
  "Operations": [{ "op": "Replace", "path": "active", "value": false }]
}</pre>
                        </div>
                        <div class="col-md-6">
                            <p><strong>@localizer["SsoScimExampleFullUpdate"]</strong></p>
                            <pre class="pre-scrollable small">PUT @(Model.ScimBaseUrl)/Users/{scim-user-id}
Authorization: Bearer &lt;your-scim-token&gt;
@(Resgrid.Config.SsoConfig.ScimDepartmentIdHeaderName): @Model.DepartmentId
Content-Type: application/scim+json

{
  "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
  "id": "{scim-user-id}",
  "userName": "jane.doe@example.com",
  "name": { "givenName": "Jane", "familyName": "Doe" },
  "emails": [{ "value": "jane.doe@example.com", "primary": true }],
  "active": true
}</pre>
                        </div>
                    </div>
                    <!-- ── Link to full per-IdP setup guide ──────────────────── -->
                    <div class="alert alert-info m-t-md m-b-none">
                        <i class="fa fa-book"></i>
                        @localizer["SsoScimSetupPageNote"]
                        @if (Model.Configs.Any())
                        {
                            <ul class="m-t-xs m-b-none">
                                @foreach (var c in Model.Configs)
                                {
                                    <li>
                                        <a asp-action="ScimSetup" asp-route-id="@c.DepartmentSsoConfigId">
                                            <i class="fa fa-external-link"></i>
                                            @localizer["SsoScimFullSetupLink"] — @c.ProviderType.ToUpperInvariant()
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="m-t-xs m-b-none">
                                <a asp-action="SsoNew" asp-route-providerType="oidc">
                                    <i class="fa fa-plus"></i> @localizer["SsoAddOidcButton"]
                                </a>
                                &nbsp;|&nbsp;
                                <a asp-action="SsoNew" asp-route-providerType="saml2">
                                    <i class="fa fa-plus"></i> @localizer["SsoAddSamlButton"]
                                </a>
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── SSO Config list ─────────────────────────────────────────── -->
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5><i class="fa fa-key"></i> @localizer["SsoConfigurationsHeader"]</h5>
                </div>
                <div class="ibox-content">
                    @if (!Model.Configs.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fa fa-exclamation-triangle"></i>
                            @localizer["SsoNoConfigurationsWarning"]
                        </div>
                    }
                    else
                    {
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>@localizer["SsoTableColProvider"]</th>
                                    <th>@localizer["SsoTableColIdentifier"]</th>
                                    <th>@localizer["SsoTableColStatus"]</th>
                                    <th>@localizer["SsoTableColLocalLogin"]</th>
                                    <th>@localizer["SsoTableColAutoProvision"]</th>
                                    <th>@localizer["SsoTableColScim"]</th>
                                    <th>@localizer["SsoTableColCreated"]</th>
                                    <th>@localizer["SsoTableColActions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Configs)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge badge-@(c.ProviderType == "oidc" ? "primary" : "info")">
                                                @c.ProviderType.ToUpperInvariant()
                                            </span>
                                        </td>
                                        <td>
                                            <small>@c.Identifier</small><br />
                                            <small class="text-muted">@c.EndpointUrl</small>
                                        </td>
                                        <td>
                                            @if (c.IsEnabled)
                                            {
                                                <span class="badge badge-success"><i class="fa fa-check"></i> @localizer["SsoStatusEnabled"]</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger"><i class="fa fa-times"></i> @localizer["SsoStatusDisabled"]</span>
                                            }
                                        </td>
                                        <td>
                                            @if (c.AllowLocalLogin)
                                            {
                                                @localizer["SsoLocalLoginYes"]
                                            }
                                            else
                                            {
                                                <span class="badge badge-warning">@localizer["SsoLocalLoginSsoOnly"]</span>
                                            }
                                        </td>
                                        <td>
                                            @if (c.AutoProvisionUsers)
                                            {
                                                <span class="badge badge-success">@localizer["SsoAutoProvisionOn"]</span>
                                            }
                                            else
                                            {
                                                @localizer["SsoAutoProvisionOff"]
                                            }
                                        </td>
                                        <td>
                                            @if (c.ScimEnabled && c.HasScimBearerToken)
                                            {
                                                <a asp-action="ScimSetup" asp-route-id="@c.DepartmentSsoConfigId">
                                                    <span class="badge badge-success"><i class="fa fa-check"></i> @localizer["SsoScimStatusActive"]</span>
                                                </a>
                                            }
                                            else if (c.ScimEnabled)
                                            {
                                                <a asp-action="ScimSetup" asp-route-id="@c.DepartmentSsoConfigId">
                                                    <span class="badge badge-warning">@localizer["SsoScimStatusNoToken"]</span>
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-action="ScimSetup" asp-route-id="@c.DepartmentSsoConfigId">
                                                    <span class="badge badge-default">@localizer["SsoScimStatusOff"]</span>
                                                </a>
                                            }
                                        </td>
                                        <td><small>@c.CreatedOn.ToString("yyyy-MM-dd")</small></td>
                                        <td>
                                            <div class="btn-group btn-group-xs">
                                                <a asp-action="SsoEdit" asp-route-id="@c.DepartmentSsoConfigId"
                                                   class="btn btn-xs btn-default" title="@localizer["SsoEditButton"]">
                                                    <i class="fa fa-pencil"></i> @localizer["SsoEditButton"]
                                                </a>
                                                <a asp-action="ScimSetup" asp-route-id="@c.DepartmentSsoConfigId"
                                                   class="btn btn-xs btn-info" title="@localizer["SsoScimSetupButton"]">
                                                    <i class="fa fa-users"></i> @localizer["SsoScimSetupButton"]
                                                </a>
                                                <button type="button"
                                                        class="btn btn-xs btn-@(c.HasScimBearerToken ? "warning" : "success")"
                                                        title="@(c.HasScimBearerToken ? localizer["SsoScimRotateTokenButton"] : localizer["SsoScimProvisionTokenButton"])"
                                                        onclick="confirmProvisionToken('@c.DepartmentSsoConfigId', @(c.HasScimBearerToken ? "true" : "false"))">
                                                    <i class="fa fa-key"></i> @(c.HasScimBearerToken ? localizer["SsoScimRotateTokenButton"] : localizer["SsoScimProvisionTokenButton"])
                                                </button>
                                                <button type="button" class="btn btn-xs btn-danger"
                                                        onclick="confirmDelete('@c.DepartmentSsoConfigId', '@c.ProviderType.ToUpperInvariant()')"
                                                        title="@localizer["SsoDeleteButton"]">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                <h4 class="modal-title">@localizer["SsoDeleteConfirmTitle"]</h4>
            </div>
            <div class="modal-body">
                <p id="deleteConfirmText"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">@localizer["SsoDeleteCancelButton"]</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">@localizer["SsoDeleteButton"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Provision / Rotate SCIM token confirmation modal -->
<div class="modal fade" id="provisionTokenModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                <h4 class="modal-title"><i class="fa fa-key"></i> @localizer["SsoScimTokenModalTitle"]</h4>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fa fa-exclamation-triangle"></i>
                    <span id="provisionTokenModalMessage"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">@localizer["SsoDeleteCancelButton"]</button>
                <form id="provisionTokenForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary" id="provisionTokenSubmit">
                        <i class="fa fa-key"></i> <span id="provisionTokenSubmitLabel"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteConfirmTemplate = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(localizer["SsoDeleteConfirmMessage"].Value));
        var rotateConfirmMsg = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(localizer["SsoScimTokenModalRotateConfirm"].Value));
        var provisionConfirmMsg = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(localizer["SsoScimTokenModalProvisionConfirm"].Value));
        var provisionLabel = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(localizer["SsoScimProvisionTokenButton"].Value));
        var rotateLabel = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(localizer["SsoScimRotateTokenButton"].Value));
        var newScimConfigId = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.NewScimConfigId ?? ""));

        function confirmDelete(id, provider) {
            document.getElementById('deleteConfirmText').textContent =
                deleteConfirmTemplate.replace('{0}', provider);
            document.getElementById('deleteForm').action = '@Url.Action("SsoDelete", "Security", new { area = "User" })/' + id;
            $('#deleteModal').modal('show');
        }

        function confirmProvisionToken(id, hasToken) {
            var isRotate = hasToken === true || hasToken === 'true';
            document.getElementById('provisionTokenModalMessage').textContent = isRotate ? rotateConfirmMsg : provisionConfirmMsg;
            document.getElementById('provisionTokenSubmitLabel').textContent = isRotate ? rotateLabel : provisionLabel;
            document.getElementById('provisionTokenForm').action =
                '@Url.Action("GenerateScimTokenFromSso", "Security", new { area = "User" })/' + id;
            $('#provisionTokenModal').modal('show');
        }

        function copyToClipboard(fieldId) {
            var el = document.getElementById(fieldId);
            el.select();
            document.execCommand('copy');
            toastr.success('@localizer["SsoCopiedToClipboard"]');
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Auto-scroll to and select the new token field when one was just generated
            if (newScimConfigId && document.getElementById('newTokenAlert')) {
                document.getElementById('newTokenAlert').scrollIntoView({ behavior: 'smooth', block: 'start' });
                var tokenField = document.getElementById('newTokenField');
                if (tokenField) { tokenField.select(); }
            }
        });
    </script>
}

<style>
    .font-monospace { font-family: SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.9em; }
    pre.pre-scrollable { max-height: 180px; overflow-y: auto; background: #f5f5f5; padding: 10px; border-radius: 4px; font-size: 0.82em; white-space: pre-wrap; word-break: break-all; }
</style>

