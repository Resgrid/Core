@using Resgrid.Model
@model Resgrid.Web.Areas.User.Models.Shifts.NewShiftView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Shifts.Shifts> localizer
@{
    ViewBag.Title = "Resgrid | " + localizer["NewShiftHeader"];
    Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";
}

<link rel="stylesheet" href="~/lib/bootstrapvalidator/css/bootstrapValidator.css" />

<style>
    .ui-datepicker {
        width: 100% !important;
    }

    .nav > li.active {
        border-left: 0px solid #2185c2;
        color: #FFFFFF !important;
    }
</style>

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-4">
        <h2>@localizer["NewShiftHeader"]</h2>
        <ol class="breadcrumb">
            <li>
                <a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
            </li>
            <li>
                <a asp-controller="Shifts" asp-action="Index" asp-route-area="User">@localizer["ShiftsHeader"]</a>
            </li>
            <li class="active">
                <strong>@localizer["NewShiftHeader"]</strong>
            </li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-xs-12">
        <div class="wrapper wrapper-content">
            <div class="ibox float-e-margins">
                <div class="ibox-content">
                    <form class="form-horizontal" role="form" asp-controller="Shifts" asp-action="NewShift" asp-route-area="User" method="post" id="new_shift" name="new_shift">
                        <div id="rootwizard">
                            <div class="navbar">
                                <div class="navbar-inner">
                                    <div class="container">
                                        <ul>
                                            <li><a href="#tab1" data-toggle="tab">@localizer["WizardStart"]</a></li>
                                            <li><a href="#tab2" data-toggle="tab">@localizer["WizardSchedule"]</a></li>
                                            <li><a href="#tab3" data-toggle="tab">@localizer["WizardSlots"]</a></li>
                                            <li><a href="#tab4" data-toggle="tab">@localizer["WizardPersonnel"]</a></li>
                                            <li><a href="#tab5" data-toggle="tab">@localizer["WizardFinish"]</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-content">
                                <div class="tab-pane" id="tab1">
                                    <div class="row">
                                        <div class="col-xs-12">
                                            <p>@localizer["NewShiftWizardIntro"]</p>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["NameLabel"]</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" placeholder="@localizer["NamePlaceholder"]" asp-for="Shift.Name" name="Shift_Name">
                                            <span class="help-block m-b-none">@localizer["NameHelp"]</span>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["CodeLabel"]</label>
                                        <div class="col-sm-4">
                                            <input type="text" class="form-control" asp-for="Shift.Code" name="Shift_Code">
                                            <span class="help-block m-b-none">@localizer["CodeHelp"]</span>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["AssignmentTypeLabel"]</label>
                                        <div class="col-sm-10">
                                            <select asp-for="AssignmentType" asp-items="ViewBag.ShiftAssignmentTypes" style="padding-left: 0; width: 40%;" class="form-control"></select>
                                            <span class="help-inline">@localizer["AssignmentTypeHelp"]</span>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["ColorLabel"]</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" asp-for="Shift.Color" id="colorPicker">
                                            <span class="help-block m-b-none">@localizer["ShiftColorNote"]</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="tab-pane" id="tab2">
                                    <div class="row">
                                        <div class="col-xs-12">
                                            <p>@localizer["ScheduleTabIntro"]</p>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["StartTimeLabel"]</label>
                                        <div class="col-sm-3">
                                            <input type="text" class="form-control" asp-for="Shift.StartTime" name="Shift_StartTime" onkeydown="javascript:return false;">
                                            <span class="help-block m-b-none">@localizer["StartTimeHelp"]</span>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["EndTimeLabel"]</label>
                                        <div class="col-sm-3">
                                            <input type="text" class="form-control" asp-for="Shift.EndTime" name="Shift_EndTime" onkeydown="javascript:return false;">
                                            <span class="help-block m-b-none">@localizer["EndTimeHelp"]</span>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <div class="col-sm-12">
                                            <div id="manualScheduleCalendar"></div>
                                            @Html.HiddenFor(m => m.Dates)
                                        </div>
                                    </div>
                                </div>
                                <div class="tab-pane" id="tab3">
                                    <div class="row">
                                        <div class="col-xs-12">
                                            <p>@localizer["SlotsTabIntro"]</p>
                                        </div>
                                    </div>
                                    <table id="groups" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th style="font-size: 14px;">@localizer["ShiftGroupColumn"]</th>
                                                <th style="font-size: 14px;">@localizer["ShiftRolesColumn"]</th>
                                                <th style="font-size: 16px;"><a id="addGroupButton" class="btn btn-success btn-xs" onclick="resgrid.shifts.newshift.addGroup();" data-original-title="@localizer["AddGroupToShift"]"><i class="icon-plus"></i> @localizer["AddGroupToShift"]</a></th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                                <div class="tab-pane" id="tab4">
                                    <div class="row">
                                        <div class="col-xs-12">
                                            <p>@localizer["PersonnelTabIntro"]</p>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label class="col-sm-2 control-label">@localizer["NonGroupPersonnelLabel"]</label>
                                        <div class="col-sm-10">
                                            <select id="shiftPersonnel" name="shiftPersonnel" style="width: 100%;"></select>
                                            <span class="help-block m-b-none">@localizer["NonGroupPersonnelHelp"]</span>
                                        </div>
                                    </div>

                                    @foreach (var group in Model.Groups)
                                    {
                                        <div class="form-group">
                                            <label class="col-sm-2 control-label">@group.Name</label>
                                            <div class="col-sm-10">
                                                <select id="groupPersonnel_@group.DepartmentGroupId" name="groupPersonnel_@group.DepartmentGroupId" class="groupPersonnelSelect" style="width: 100%;"></select>
                                            </div>
                                        </div>
                                    }

                                </div>
                                <div class="tab-pane" id="tab5">
                                    <div class="row">
                                        <div class="col-xs-12 padding">
                                            <p>@localizer["FinishTabIntro"]</p>
                                        </div>
                                    </div>
                                    <span class="alert alert-error">
                                        @Html.ValidationSummary(false)
                                        @Html.AntiForgeryToken()
                                    </span>
                                </div>
                                <ul class="pager wizard" style="display:block;">
                                    <li class="previous first" style="display:none;"><a href="#">@localizer["WizardFirst"]</a></li>
                                    <li class="previous"><a href="#">@localizer["WizardPrevious"]</a></li>
                                    <li class="next"><a href="#">@localizer["WizardNext"]</a></li>
                                    <li class="next finish" style="display:none;"><a href="#">@localizer["WizardFinish"]</a></li>
                                </ul>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/lib/twitter-bootstrap-wizard/jquery.bootstrap.wizard.min.js"></script>
    <script src="~/lib/bootstrapvalidator/js/bootstrapValidator.min.js"></script>
    <script src="~/lib/jquery-ui-multidatespicker/jquery-ui.multidatespicker.js"></script>

    <script>
        $(document).ready(function () {
            $('.sl2').select2();

            $("#colorPicker").minicolors({
                animationSpeed: 50,
                animationEasing: 'swing',
                changeDelay: 0,
                control: 'hue',
                defaultValue: '#0080ff',
                format: 'hex',
                showSpeed: 100,
                hideSpeed: 100,
                inline: false,
                theme: 'bootstrap'
            });

            //var $validator = $("#new_shift").validate({
            //	rules: {
            //		Shift_Name: {
            //			required: true,
            //			minlength: 3
            //		},
            //		"Shift.Code": {
            //			required: true,
            //			minlength: 1
            //		}
            //	}
            //});

            var $validator = $("#new_shift").bootstrapValidator({
                excluded: [':disabled', ':hidden', ':not(:visible)'],
                fields: {
                    Shift_Name: {
                        validators: {
                            notEmpty: {
                                message: '@localizer["ShiftNameRequired"]'
                            }
                        }
                    },
                    Shift_Code: {
                        validators: {
                            notEmpty: {
                                message: '@localizer["ShiftCodeRequired"]'
                            }
                        }
                    },
                    Shift_StartTime: {
                        validators: {
                            notEmpty: {
                                message: '@localizer["ShiftStartTimeRequired"]'
                            }
                        }
                    }
                }
            });

            $('#rootwizard').bootstrapWizard({
                onTabShow: function (tab, navigation, index) {
                    var $total = navigation.find('li').length;
                    var $current = index + 1;
                    //var $percent = ($current / $total) * 100;
                    //$('#rootwizard').find('.bar').css({ width: $percent + '%' });

                    // If it's the last tab then hide the last button and show the finish instead
                    if ($current >= $total) {
                        $('#rootwizard').find('.pager .next').hide();
                        $('#rootwizard').find('.pager .finish').show();
                        $('#rootwizard').find('.pager .finish').removeClass('disabled');
                    } else {
                        $('#rootwizard').find('.pager .next').show();
                        $('#rootwizard').find('.pager .finish').hide();
                    }
                },
                onTabClick: function (tab, navigation, index) {
                    return false;
                },
                onNext: function (tab, navigation, index) {
                    var $validate = $("#new_shift").data('bootstrapValidator').validate();

                    var $valid = $validate.isValid();
                    if (!$valid) {
                        return false;
                    }

                    //var $total = navigation.find('li').length;
                    //var $current = index + 1;
                    //if ($current >= $total) {
                    //    $("form#new_shift").submit();
                    //}
                }
            });

            $('#AssignmentType').on("change", function (e) {
                if (e.val === '1') {
                    $('#rootwizard').bootstrapWizard('disable', 3);
                    //$('#rootwizard').bootstrapWizard('enable', 2);
                } else {
                    $('#rootwizard').bootstrapWizard('enable', 3);
                    //$('#rootwizard').bootstrapWizard('disable', 2);
                }
            });

            var today = new Date();
            var y = today.getFullYear();
            $('#manualScheduleCalendar').multiDatesPicker({
                //addDates: ['10/14/' + y, '02/19/' + y, '01/14/' + y, '11/16/' + y],
                numberOfMonths: [3, 4] //,
                //defaultDate: '1/1/' + y
            });

            $('#rootwizard .finish').click(function () {
                var dates = $('#manualScheduleCalendar').multiDatesPicker('getDates');
                $('#Dates').val(dates);
                $("form#new_shift")[0].submit();
                //$("form")[0].submit();
            });

            $('#manualScheduleCalendar').children().first().css('width', '100%');
            //$('#rootwizard').bootstrapWizard('disable', 2);
            //$('#manualScheduleCalendar').children().first().removeClass('width');
        });

        function addGroupRoleField(name) {
            var newField = $(name);
            $('#new_shift').bootstrapValidator('addField', newField);
        }
    </script>
    <script>
        var resgridShiftsI18n = {
            addGroupToShift: '@localizer["AddGroupToShift"]',
            shiftGroupColumn: '@localizer["ShiftGroupColumn"]',
            shiftRolesColumn: '@localizer["ShiftRolesColumn"]',
            shiftRoleColumn: '@localizer["ShiftRoleColumn"]',
            rolesCountColumn: '@localizer["RolesCountColumn"]',
            addRoleToGroup: '@localizer["AddRoleToGroup"]',
            addShiftRolesToGroup: '@localizer["AddShiftRolesToGroup"]',
            removeGroup: '@localizer["RemoveGroup"]',
            removeRole: '@localizer["RemoveRole"]',
            removeRoleFromGroup: '@localizer["RemoveRoleFromGroup"]',
            roleCountRequired: '@localizer["RoleCountRequired"]',
            selectNonGroupPersonnel: '@localizer["SelectNonGroupPersonnel"]',
            selectPersonnelForGroup: '@localizer["SelectPersonnelForGroup"]'
        };
    </script>
    <script src="~/js/app/internal/shifts/resgrid.shifts.newshift.js"></script>
}
