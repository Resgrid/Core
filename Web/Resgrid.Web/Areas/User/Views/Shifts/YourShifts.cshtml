@using Resgrid.Model
@using Resgrid.Model.Helpers
@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Shifts.YourShiftsView
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Shifts.Shifts> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["YourShiftsHeader"];
	Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["YourShiftsHeader"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a>
			</li>
			<li>
				<a asp-controller="Shifts" asp-action="Index" asp-route-area="User">@localizer["ShiftsHeader"]</a>
			</li>
			<li class="active">
				<strong>@localizer["YourShiftsHeader"]</strong>
			</li>
		</ol>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
		<div class="wrapper wrapper-content">
			<div class="ibox float-e-margins">
				<div class="ibox-title">
					<h5>@localizer["YourShiftsHeader"]</h5>
				</div>
				<div class="ibox-content">
					<div class="table-responsive">
						<table class="table table-striped">
							<thead>
								<tr>
									<th>@localizer["ShiftColumn"]</th>
									<th>@localizer["GroupColumn"]</th>
									<th>@localizer["DayColumn"]</th>
									<th>@localizer["ApprovedColumn"]</th>
									<th>@localizer["StatusColumn"]</th>
									<th>@localizer["TimestampColumn"]</th>
									<th class='span1'></th>
								</tr>
							</thead>
							<tbody>
								@foreach (var s in Model.Signups)
								{
									<tr>
										<td>@s.Shift.Name</td>
										<td>@s.Group.Name</td>
										<td>@s.ShiftDay.ToShortDateString()</td>
										<td>
											@if (s.Denied)
											{
												<span>@localizer["ApprovedNo"]</span>
											}
											else
											{
												<span>@localizer["ApprovedYes"]</span>
											}
										</td>
										<td>
											@if (s.Trade != null && s.Trade.IsTradeComplete())
											{
												<span class='label label-success'>@localizer["TradeComplete"]</span>
											}
											else if (s.Trade != null && !s.Trade.IsTradeComplete())
											{
												<span class='label label-warning'>@localizer["TradeInProgress"]</span>
											}
											else
											{
												<span class="label label-primary">@localizer["Normal"]</span>
											}
										</td>
										<td>@s.SignupTimestamp.TimeConverterToString(Model.Department)</td>
										<td>
											@if (s.ShiftDay > DateTime.UtcNow.TimeConverter(Model.Department) && s.Trade == null)
											{
												<a type="button" href="@Url.Action("DeclineShiftDay", "Shifts", new {area = "User", shiftSignupId = s.ShiftSignupId})" data-confirm="@localizer["DeclineShiftDayWarning"] @s.Shift.Name @localizer["For"] @s.ShiftDay.ToShortDateString()?" rel="nofollow" class="btn btn-xs btn-danger"><i class='icon-trash'></i> @localizer["DeclineShiftDay"]</a>
											}
											@if (s.ShiftDay > DateTime.UtcNow.TimeConverter(Model.Department) && s.Trade == null)
											{
												<a type="button" href="@Url.Action("RequestTrade", "Shifts", new {area = "User", shiftSignupId = s.ShiftSignupId})" class="btn btn-xs btn-primary"><i class='icon-refresh'></i> @localizer["RequestTrade"]</a>
											}
											@if (s.Trade != null && !s.Trade.IsTradeComplete())
											{
												<a type="button" href="@Url.Action("FinishTrade", "Shifts", new { area = "User", shiftSignupTradeId = s.Trade.ShiftSignupTradeId })" class="btn btn-xs btn-info"><i class='icon-ok'></i> @localizer["FinishTrade"]</a>
											}
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="row">
	<div class="col-xs-12">
		<div class="wrapper wrapper-content">
			<div class="ibox float-e-margins">
				<div class="ibox-title">
					<h5>@localizer["YourPendingTrades"]</h5>
				</div>
				<div class="ibox-content">
					<div class="table-responsive">
						<table class="table table-striped">
							<thead>
								<tr>
									<th>@localizer["ShiftColumn"]</th>
									<th>@localizer["GroupColumn"]</th>
									<th>@localizer["DayColumn"]</th>
									<th>@localizer["TimeColumn"]</th>
									<th class='span1'></th>
								</tr>
							</thead>
							<tbody>
								@foreach (var t in Model.Trades)
								{
									<tr>
										<td>@t.SourceShiftSignup.Shift.Name</td>
										<td>@t.SourceShiftSignup.Group.Name</td>
										<td>@t.SourceShiftSignup.ShiftDay.ToShortDateString()</td>
										<td>@t.SourceShiftSignup.Shift.StartTime</td>
										<td>
											@if (t.GetState(ClaimsAuthorizationHelper.GetUserId()) == ShiftSignupTradeStates.Open)
											{
												<a type="button" href="@Url.Action("ProcessTrade", "Shifts", new {area = "User", shiftSignupTradeId = t.ShiftSignupTradeId})" class="btn btn-xs btn-primary"><i class='icon-check'></i> @localizer["ProcessTradeRequest"]</a>
											}
											else if (t.GetState(ClaimsAuthorizationHelper.GetUserId()) == ShiftSignupTradeStates.Declined)
											{
												<span class="label label-danger">@localizer["Declined"]</span>
											}
											else if (t.GetState(ClaimsAuthorizationHelper.GetUserId()) == ShiftSignupTradeStates.Accepted)
											{
												<span class="label label-success">@localizer["Accepted"]</span>
											}
											else if (t.GetState(ClaimsAuthorizationHelper.GetUserId()) == ShiftSignupTradeStates.Filled)
											{
												<span class="label label-info">@localizer["Filled"]</span>
											}
											else if (t.GetState(ClaimsAuthorizationHelper.GetUserId()) == ShiftSignupTradeStates.Proposed)
											{
												<span class="label label-info">@localizer["TradeOffered"]</span>
											}
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts
{

}
