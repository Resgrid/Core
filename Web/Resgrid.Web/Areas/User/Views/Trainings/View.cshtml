@using Resgrid.Web.Helpers
@model Resgrid.Web.Areas.User.Models.Training.ViewTrainingModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Trainings.Trainings> localizer
@{
	ViewBag.Title = "Resgrid | " + localizer["ViewTrainingHeader"];
}
@section Styles
{

}

@{
	var currentUser = Model.Training.Users.FirstOrDefault(x => x.UserId == ClaimsAuthorizationHelper.GetUserId());
}

<div class="row wrapper border-bottom white-bg page-heading">
	<div class="col-sm-4">
		<h2>@localizer["ViewTrainingHeader"]</h2>
		<ol class="breadcrumb">
			<li>
				<a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@localizer["HomeLink"]</a>
			</li>
			<li>
				<a asp-controller="Trainings" asp-action="Index" asp-route-area="User">@localizer["TrainingsLink"]</a>
			</li>
			<li class="active">
				<strong>@localizer["ViewTrainingHeader"]</strong>
			</li>
		</ol>
	</div>
</div>

<div class="row">
	<div class="col-lg-9">
		<div class="wrapper wrapper-content animated fadeInUp">
			<div class="ibox">
				<div class="ibox-content">
					<div class="row">
						<div class="col-lg-5">
							<div class="m-b-md">
								<h2>@Model.Training.Name</h2>
							</div>
						</div>
					</div>
					<div class="row">
						<div class="col-lg-5">
							<dl class="dl-horizontal">
								<dt>@localizer["StatusLabel"]</dt>
								<dd><span class="label label-primary">@localizer["ActiveLabel"]</span></dd>
							</dl>
						</div>
						<div class="col-lg-7">
							<dl class="dl-horizontal">
								<dt>@localizer["CreatedByLabel"]</dt>
								<dd>@Model.CreatorUserName</dd>
							</dl>
						</div>
					</div>
					<div class="row">
						<div class="col-lg-5">
							<dl class="dl-horizontal">
								<dt>@localizer["DueByLabel"]</dt>
								<dd>
									@if (Model.Training.ToBeCompletedBy != null)
									{
										<span>@Model.Training.ToBeCompletedBy.Value.ToShortDateString()</span>
									}
									else
									{
										<span>@localizer["NoDueDate"]</span>
									}
								</dd>
							</dl>
						</div>
						<div class="col-lg-7">
							<dl class="dl-horizontal">
								<dt>@localizer["CreatedOnLabel"]</dt>
								<dd>@Model.Training.CreatedOn.ToShortDateString()</dd>
							</dl>
						</div>
					</div>
					<div class="row">
						<div class="col-lg-12">
							<dl class="dl-horizontal">
								<dt>@localizer["DescriptionLabel"]:</dt>
								<dd>
									@Html.Raw(Model.Training.Description)
								</dd>
							</dl>
						</div>
					</div>
					<div class="row">
						<div class="col-lg-10 col-lg-offset-1">
							<p>
								@Html.Raw(Model.Training.TrainingText)
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="col-lg-3">
		<div class="wrapper wrapper-content project-manager">
			<h4>@localizer["TrainingAttachmentsHeader"]</h4>
			<p class="small">
				@localizer["AttachmentsHelpText"]
			</p>
			<h5>@localizer["TrainingFilesHeader"]</h5>
			<ul class="list-unstyled project-files">
				@if (Model.Training.Attachments != null && Model.Training.Attachments.Count > 0)
				{
					foreach (var attachment in Model.Training.Attachments)
					{
						<li><a asp-controller="Trainings" asp-action="GetTrainingAttachment" asp-route-area="User" asp-route-trainingAttachmentId="@attachment.TrainingAttachmentId" target="_blank"><i class="fa fa-file"></i> @attachment.FileName</a></li>
					}
				}
			</ul>
		</div>

@if (Model.Training.Questions != null && Model.Training.Questions.Count > 0 && (currentUser != null && !currentUser.Complete))
{
		<div class="wrapper wrapper-content project-manager">
			<h4>@localizer["TrainingQuizHeader"]</h4>
			<p class="small">
				@localizer["QuizHelpText"]
			</p>

			<a class="btn btn-success btn-rounded btn-block" asp-controller="Trainings" asp-action="Quiz" asp-route-area="User" asp-route-trainingId="@Model.Training.TrainingId">@localizer["TakeQuizButton"]</a>
		</div>
}

	</div>
</div>

@section Scripts
{

}
