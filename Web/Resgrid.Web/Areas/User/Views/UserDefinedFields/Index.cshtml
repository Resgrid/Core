@model Resgrid.Web.Areas.User.Models.UserDefinedFields.UdfIndexModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.UserDefinedFields.UserDefinedFields> localizer
@{
    ViewData["Title"] = "Resgrid | " + localizer["PageHeader"];
    Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";
    var successMessage = TempData["SuccessMessage"] as string;
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-8">
        <h2>@localizer["PageHeader"]</h2>
        <ol class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Dashboard" asp-route-area="User">@commonLocalizer["HomeModule"]</a></li>
            <li class="active"><strong>@localizer["UdfModule"]</strong></li>
        </ol>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success alert-dismissable">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                    @localizer[successMessage]
                </div>
            }

            <div class="ibox float-e-margins">
                <div class="ibox-title">
                    <h5>@localizer["UdfSummaryTitle"]</h5>
                    <div class="ibox-tools">
                        <small class="text-muted">@localizer["PageSubHeader"]</small>
                    </div>
                </div>
                <div class="ibox-content">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>@localizer["EntityType"]</th>
                                <th>@localizer["Version"]</th>
                                <th>@localizer["FieldCount"]</th>
                                <th>@localizer["Status"]</th>
                                <th>@localizer["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entity in Model.Entities)
                            {
                                <tr>
                                    <td><strong>@localizer["Entity" + entity.EntityType.ToString()]</strong></td>
                                    <td>
                                        @if (entity.ActiveDefinition != null)
                                        {
                                            <span>v@(entity.ActiveDefinition.Version)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (entity.ActiveDefinition != null)
                                        {
                                            <span class="badge badge-primary">@entity.FieldCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (entity.ActiveDefinition != null)
                                        {
                                            <span class="label label-success">@localizer["Active"]</span>
                                        }
                                        else
                                        {
                                            <span class="label label-default">@localizer["NoDefinition"]</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Edit"
                                           asp-route-entityType="@((int)entity.EntityType)"
                                           class="btn btn-xs btn-primary">
                                            <i class="fa fa-pencil"></i>
                                            @if (entity.ActiveDefinition != null)
                                            {
                                                @localizer["Edit"]
                                            }
                                            else
                                            {
                                                @localizer["Configure"]
                                            }
                                        </a>

                                        @if (entity.ActiveDefinition != null && entity.FieldCount > 0)
                                        {
                                            <button type="button"
                                                    class="btn btn-xs btn-info btn-preview-udf"
                                                    data-entity-type="@((int)entity.EntityType)"
                                                    data-entity-name="@localizer["Entity" + entity.EntityType.ToString()]"
                                                    data-preview-url="@Url.Action("Preview", "UserDefinedFields", new { area = "User", entityType = (int)entity.EntityType })">
                                                <i class="fa fa-eye"></i> @localizer["Preview"]
                                            </button>

                                            var confirmMsg = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(
                                                string.Format(localizer["DeleteDefinitionConfirm"].Value,
                                                    localizer["Entity" + entity.EntityType.ToString()].Value));
                                            <form asp-action="Delete" method="post" style="display:inline;"
                                                  onsubmit="return confirm('@Html.Raw(confirmMsg)');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="entityType" value="@((int)entity.EntityType)" />
                                                <button type="submit" class="btn btn-xs btn-danger">
                                                    <i class="fa fa-trash"></i> @localizer["Delete"]
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- UDF Preview Modal -->
<div class="modal inmodal fade" id="udfPreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="udfPreviewModalLabel">@localizer["Preview"]</h4>
            </div>
            <div class="modal-body" id="udfPreviewModalBody">
                <div class="text-center" id="udfPreviewSpinner">
                    <i class="fa fa-spinner fa-spin fa-2x text-muted"></i>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    <i class="fa fa-times"></i> @localizer["Close"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function ($) {
            'use strict';

            var previewTitleTemplate = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(localizer["PreviewModalTitle"].Value))';

            $(document).on('click', '.btn-preview-udf', function () {
                var $btn        = $(this);
                var previewUrl  = $btn.data('preview-url');
                var entityName  = $btn.data('entity-name');
                var $modal      = $('#udfPreviewModal');
                var $body       = $('#udfPreviewModalBody');
                var $spinner    = $('#udfPreviewSpinner');
                var $title      = $('#udfPreviewModalLabel');

                $title.text(previewTitleTemplate.replace('{0}', entityName));
                $body.html($spinner.clone().show());
                $modal.modal('show');

                $.ajax({
                    url: previewUrl,
                    type: 'GET',
                    success: function (html) {
                        $body.html(html);
                    },
                    error: function () {
                        $body.html('<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> Failed to load preview. Please try again.</div>');
                    }
                });
            });

        }(jQuery));
    </script>
}
