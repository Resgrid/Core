@model Resgrid.Web.Models.AccountViewModels.ForcePasswordChangeViewModel
@inject IStringLocalizer<Resgrid.Localization.Areas.User.Account.ForcePasswordChange> localizer
@{
    ViewData["Title"] = localizer["PageTitle"];
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-sm-12">
        <h2><i class="fa fa-lock"></i> @localizer["PageHeader"]</h2>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-md-6 col-md-offset-3">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>@localizer["ExpiredTitle"]</h5>
                </div>
                <div class="ibox-content">
                    <div class="alert alert-warning">
                        <i class="fa fa-exclamation-triangle"></i>
                        @localizer["AlertWarningText"]
                    </div>

                    <div class="alert alert-info">
                        <strong><i class="fa fa-info-circle"></i> @localizer["RequirementsHeader"]:</strong>
                        <ul class="m-t-xs m-b-none">
                            <li>@string.Format(localizer["ReqLength"], Model.MinPasswordLength)</li>
                            <li>@localizer["ReqDigit"]</li>
                            <li>@localizer["ReqUppercase"]</li>
                            <li>@localizer["ReqLowercase"]</li>
                        </ul>
                    </div>

                    <form asp-controller="Account" asp-action="ForcePasswordChange" method="post" class="form-horizontal">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="form-group">
                            <label asp-for="CurrentPassword" class="col-sm-4 control-label">@localizer["CurrentPasswordLabel"]</label>
                            <div class="col-sm-8">
                                <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
                                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="NewPassword" class="col-sm-4 control-label">@localizer["NewPasswordLabel"]</label>
                            <div class="col-sm-8">
                                <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword" class="col-sm-4 control-label">@localizer["ConfirmPasswordLabel"]</label>
                            <div class="col-sm-8">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-sm-offset-4 col-sm-8">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"></i> @Html.Raw(localizer["SubmitButton"])
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
